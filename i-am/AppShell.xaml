<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="i_am.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:auth="clr-namespace:i_am.Pages.Authentication"
    xmlns:local="clr-namespace:i_am"
    xmlns:main="clr-namespace:i_am.Pages.Main"
    Title="i_am"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Title="Loading"
        ContentTemplate="{DataTemplate auth:LoadingPage}"
        Route="LoadingPage" />
    <ShellContent
        Title="Welcome"
        ContentTemplate="{DataTemplate auth:LandingPage}"
        Route="LandingPage" />
    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate main:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="Uprawnienia"
        ContentTemplate="{DataTemplate main:PermissionsPage}"
        Route="PermissionsPage" />
</Shell>
