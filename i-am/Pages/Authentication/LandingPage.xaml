<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="i_am.Pages.Authentication.LandingPage"
             Title="LandingPage"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Spacing="20" 
                         Padding="30" 
                         VerticalOptions="Center">

        <Image Source="{AppThemeBinding Light=i_am_logo_black.svg, Dark=i_am_logo_white.svg}" 
               HeightRequest="150" 
               HorizontalOptions="Center" 
               Margin="0,0,0,20" />

        <Button Text="Logowanie" 
                Clicked="OnLoginClicked" 
                Margin="0,0,0,10" />

        <Button Text="Rejestracja" 
                Clicked="OnRegisterClicked" 
                BackgroundColor="Transparent" 
                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDarkText}}" 
                BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                BorderWidth="2" />
    </VerticalStackLayout>
</ContentPage>