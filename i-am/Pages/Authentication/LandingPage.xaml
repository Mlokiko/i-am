<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        x:Class="i_am.Pages.Authentication.LandingPage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:local="clr-namespace:i_am.Resources.Strings"
        Shell.NavBarIsVisible="False">

        <VerticalStackLayout
                Padding="30"
                Spacing="20"
                VerticalOptions="Center">

                <Image
                        Margin="0,0,0,20"
                        HeightRequest="150"
                        HorizontalOptions="Center"
                        Source="{AppThemeBinding Light=i_am_logo_black.svg,
                                                 Dark=i_am_logo_white.svg}" />

                <Button
                        Margin="0,0,0,10"
                        Clicked="OnLoginClicked"
                        Text="{Binding Source={x:Static local:AppStrings.Landing_Login}}" />

                <Button
                        BackgroundColor="Transparent"
                        BorderColor="{AppThemeBinding Light={StaticResource Primary},
                                                      Dark={StaticResource PrimaryDark}}"
                        BorderWidth="2"
                        Clicked="OnRegisterClicked"
                        Text="{Binding Source={x:Static local:AppStrings.Landing_Register}}"
                        TextColor="{AppThemeBinding Light={StaticResource Primary},
                                                    Dark={StaticResource PrimaryDarkText}}" />
        </VerticalStackLayout>
</ContentPage>
