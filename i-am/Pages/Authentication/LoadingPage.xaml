<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="i_am.Pages.Authentication.LoadingPage"
             Title="LoadingPage"
             Shell.NavBarIsVisible="False">
    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">

        <ActivityIndicator IsRunning="True" Color="{StaticResource Tertiary}" />

        <Label Text="Wczytywanie profilu..." TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

    </VerticalStackLayout>

</ContentPage>