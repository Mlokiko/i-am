<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="i_am.Pages.Authentication.LoginPage"
             Title="LoginPage">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

            <Label Text="Logowanie" 
                   FontSize="32" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center" 
                   Margin="0,0,0,20"/>

            <Border StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Padding="12,0">
                <Entry x:Name="EmailEntry" 
                       Placeholder="Email" 
                       Keyboard="Email"
                       ClearButtonVisibility="WhileEditing"/>
            </Border>

            <Border StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Padding="12,0">
                <Entry x:Name="PasswordEntry" 
                       Placeholder="Hasło" 
                       IsPassword="True" 
                       ClearButtonVisibility="WhileEditing"/>
            </Border>

            <Button Text="Login" 
                    Clicked="OnLoginClicked" 
                    Margin="0,20,0,0"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Nie masz konta?" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                <Label Text="Zarejestruj." TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoToRegisterTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>