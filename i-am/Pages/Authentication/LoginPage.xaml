<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Authentication.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    x:DataType="vm:LoginViewModel"
    Title="Logowanie">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Border Padding="12,0" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                <Entry
                    Text="{Binding Email}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Email"
                    Placeholder="Email" />
            </Border>

            <Border Padding="12,0" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                <Entry
                    Text="{Binding Password}"
                    ClearButtonVisibility="WhileEditing"
                    IsPassword="True"
                    Placeholder="Hasło" />
            </Border>

            <Button
                Margin="0,20,0,0"
                Command="{Binding LoginCommand}"
                Text="Login" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Nie masz konta?" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" VerticalOptions="Center" />
                <Label FontAttributes="Bold" Text="Zarejestruj." TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>