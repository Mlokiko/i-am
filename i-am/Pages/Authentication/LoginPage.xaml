<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Authentication.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Logowanie">
    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="20"
            VerticalOptions="Center">

            <Border
                Padding="12,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                  Dark={StaticResource SurfaceDark}}"
                Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                         Dark={StaticResource Gray500}}"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1">
                <Entry
                    x:Name="EmailEntry"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Email"
                    Placeholder="Email" />
            </Border>

            <Border
                Padding="12,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                  Dark={StaticResource SurfaceDark}}"
                Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                         Dark={StaticResource Gray500}}"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1">
                <Entry
                    x:Name="PasswordEntry"
                    ClearButtonVisibility="WhileEditing"
                    IsPassword="True"
                    Placeholder="Hasło" />
            </Border>

            <Button
                Margin="0,20,0,0"
                Clicked="OnLoginClicked"
                Text="Login" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label
                    Text="Nie masz konta?"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                Dark={StaticResource Gray400}}"
                    VerticalOptions="Center" />
                <Label
                    FontAttributes="Bold"
                    Text="Zarejestruj."
                    TextColor="{AppThemeBinding Light={StaticResource Primary},
                                                Dark={StaticResource PrimaryDark}}"
                    VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoToRegisterTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
