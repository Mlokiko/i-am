<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Authentication.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    xmlns:local="clr-namespace:i_am.Resources.Strings"
    Title="{Binding Source={x:Static local:AppStrings.Login_Title}}"
    x:DataType="vm:LoginViewModel">
    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="20"
            VerticalOptions="Center">

            <Border Style="{StaticResource InputBorderStyle}">
                <Entry
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Email"
                    Placeholder="{Binding Source={x:Static local:AppStrings.Login_Email}}"
                    Text="{Binding Email}" />
            </Border>

            <Border Style="{StaticResource InputBorderStyle}">
                <Entry
                    ClearButtonVisibility="WhileEditing"
                    IsPassword="True"
                    Placeholder="{Binding Source={x:Static local:AppStrings.Login_Password}}"
                    Text="{Binding Password}" />
            </Border>

            <Button
                Margin="0,20,0,0"
                Command="{Binding LoginCommand}"
                Text="{Binding Source={x:Static local:AppStrings.Login_Button}}" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Style="{StaticResource SubtitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Login_NoAccount}}" />
                <Label Style="{StaticResource LinkLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Login_SignUp}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>