<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="i_am.Pages.Authentication.RegisterPage"
             Title="Rejestracja">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="30">

            <Label 
                Text="Email"
                FontSize="16"
                FontAttributes="Bold"
                Margin="0,15,0,5"/>
            <Border x:Name="EmailBorder" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Padding="12,0">
                <Entry x:Name="EmailEntry"
       Placeholder="np. example@example.com"
       Keyboard="Email"
       Unfocused="OnEmailUnfocused"
       TextChanged="OnFieldTextChanged"/>
            </Border>
            <Label x:Name="EmailErrorLabel" Text="Niepoprawny format email" TextColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" FontSize="12" Margin="5,-10,0,0" IsVisible="False" />


            <HorizontalStackLayout Spacing="8" Margin="0,10,0,5" VerticalOptions="End">
                <Label 
                    Text="Hasło"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="0,10,0,5"/>
                <Border Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" StrokeThickness="2" BackgroundColor="Transparent"
                        StrokeShape="RoundRectangle 15" HeightRequest="24" WidthRequest="24"
                        HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="?" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPasswordInfoTapped" />
                    </Border.GestureRecognizers>
                </Border>
            </HorizontalStackLayout>
            <Border x:Name="PasswordBorder" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Padding="12,0">
                <Grid>
                    <Entry x:Name="PasswordEntry"
       Placeholder="np. MojeB@rdzoSiln3HaSlO"
       IsPassword="True" 
       Unfocused="OnPasswordUnfocused"
       TextChanged="OnFieldTextChanged"/>

                    <Label 
                        x:Name="TogglePasswordLabel"
                        Text="Pokaż" 
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                        FontAttributes="Bold" 
                        VerticalOptions="Center" 
                        HorizontalOptions="End" 
                        Margin="0,0,15,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTogglePasswordTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>
            <Label x:Name="PasswordErrorLabel" Text="Hasło musi mieć minimum 6 znaków" TextColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" FontSize="12" Margin="5,-10,0,0" IsVisible="False" />


            <Label 
                Text="Potwierdź hasło"
                FontSize="16"
                FontAttributes="Bold"
                Margin="0,10,0,5"/>
            <Border x:Name="ConfirmPasswordBorder" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Padding="12,0">
                <Grid>
                    <Entry x:Name="ConfirmPasswordEntry"
       Placeholder="Powtórz hasło"
       IsPassword="True" 
       Unfocused="OnConfirmPasswordUnfocused"
       TextChanged="OnFieldTextChanged"/>

                    <Label 
                        x:Name="ToggleConfirmPasswordLabel"
                        Text="Pokaż" 
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                        FontAttributes="Bold" 
                        VerticalOptions="Center" 
                        HorizontalOptions="End" 
                        Margin="0,0,15,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTogglePasswordTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>
            <Label x:Name="ConfirmPasswordErrorLabel" Text="Hasła nie są identyczne" TextColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" FontSize="12" Margin="5,-10,0,0" IsVisible="False" />


            <HorizontalStackLayout Spacing="8" Margin="0,10,0,5" VerticalOptions="End">
                <Label Text="Nazwa użytkownika" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                <Border Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" StrokeThickness="2" BackgroundColor="Transparent" StrokeShape="RoundRectangle 15" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="?" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNameInfoTapped" />
                    </Border.GestureRecognizers>
                </Border>
            </HorizontalStackLayout>
            <Border x:Name="NameBorder" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Padding="12,0">
                <Entry x:Name="NameEntry" Placeholder="np. Andrju" Unfocused="OnNameUnfocused" TextChanged="OnFieldTextChanged"/>
            </Border>

            <Label x:Name="NameErrorLabel" Text="Nazwa musi mieć minimum 3 znaki" TextColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" FontSize="12" Margin="5,-10,0,0" IsVisible="False" />

            <HorizontalStackLayout Spacing="8" Margin="0,10,0,5" VerticalOptions="End">
                <Label Text="Numer telefonu" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                <Border Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" StrokeThickness="2" BackgroundColor="Transparent" StrokeShape="RoundRectangle 15" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="?" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPhoneInfoTapped" />
                    </Border.GestureRecognizers>
                </Border>
            </HorizontalStackLayout>
            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Padding="12,0">
                    <Entry x:Name="PhonePrefixEntry" Text="+48" WidthRequest="50" Keyboard="Telephone" />
                </Border>
                <Border x:Name="PhoneBorder" Grid.Column="1" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" Padding="12,0">
                    <Entry x:Name="PhoneEntry" Placeholder="np. 111 222 333" Keyboard="Telephone" Unfocused="OnPhoneUnfocused" TextChanged="OnFieldTextChanged" />
                </Border>
            </Grid>
            <Label x:Name="PhoneErrorLabel" Text="Podaj poprawny numer (min. 9 cyfr)" TextColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" FontSize="12" Margin="5,5,0,0" IsVisible="False" />

            <Label Text="Data urodzenia" FontSize="16" FontAttributes="Bold" Margin="0,10,0,5"/>
            <DatePicker x:Name="BirthdatePicker" Format="dd/MM/yyyy" />

            <Label Text="Płeć" FontSize="16" FontAttributes="Bold" Margin="0,10,0,5"/>
            <Picker x:Name="SexPicker" Title="Kliknij aby wybrać z listy">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Mężczyzna</x:String>
                        <x:String>Kobieta</x:String>
                        <x:String>Inne</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <HorizontalStackLayout Spacing="10" VerticalOptions="Center" Margin="0,10,0,0">
                <Label Text="Jesteś opiekunem?" VerticalOptions="Center" />
                <Switch x:Name="CaregiverSwitch" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Button 
                x:Name="RegisterButton"
                Text="Stwórz konto" 
                Clicked="OnRegisterClicked" 
                IsEnabled="False" />

            <ActivityIndicator x:Name="LoadingSpinner" IsRunning="False" IsVisible="False" Color="white" HorizontalOptions="Center" Margin="0,10,0,0" />
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Masz już konto?" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                <Label Text="Zaloguj się." TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginClicked" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>