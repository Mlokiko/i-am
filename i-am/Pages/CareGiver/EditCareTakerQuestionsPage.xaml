<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.CareGiver.EditCareTakerQuestionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    x:DataType="vm:EditCareTakerQuestionsViewModel"
    Title="Pytania Podopiecznego">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">

            <VerticalStackLayout IsVisible="{Binding IsQuestionsVisible}" Spacing="15">

                <Label FontAttributes="Bold" FontSize="16" Text="1. Wybierz podopiecznego:" />

                <Grid Padding="10" BackgroundColor="#2D2D30">
                    <Button Text="{Binding SelectedCareTakerName}" Command="{Binding SelectCareTakerCommand}" BackgroundColor="Transparent" TextColor="White" HorizontalOptions="Start" HeightRequest="45"/>
                </Grid>

                <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center" Margin="0,10,0,0">
                    <Label Grid.Column="0" FontAttributes="Bold" FontSize="16" Text="Aktualne Pytania" VerticalOptions="Center" />
                    <Button Grid.Column="1" Command="{Binding OpenNewQuestionEditorCommand}" Text="+ Dodaj Pytanie" BackgroundColor="#0078D7" TextColor="White" HeightRequest="40" />
                </Grid>

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Questions}" Spacing="10">
                    <BindableLayout.EmptyView>
                        <Label HorizontalOptions="Center" Padding="20" Text="Brak pytań. Dodaj pierwsze używając przycisku wyżej." TextColor="Gray" />
                    </BindableLayout.EmptyView>

                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:QuestionItemViewModel">
                            <Grid Padding="15" ColumnDefinitions="*, Auto" BackgroundColor="#1E1E1E" RowSpacing="5">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="5">
                                    <Label FontAttributes="Bold" FontSize="15" Text="{Binding Text}" TextColor="White"/>

                                    <HorizontalStackLayout Spacing="8">
                                        <Label FontSize="12" TextColor="LightGray" Text="{Binding TypeText}" />
                                        <Label FontSize="12" TextColor="#0078D7" FontAttributes="Bold" Text="Codzienne" IsVisible="{Binding IsDaily}"/>
                                        <Label FontSize="12" TextColor="#FF9800" FontAttributes="Bold" Text="Losowe z puli" IsVisible="{Binding IsRandom}"/>
                                    </HorizontalStackLayout>

                                    <Label FontSize="12" TextColor="#0078D7" Text="{Binding MaxSelectionsText}" IsVisible="{Binding IsClosed}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                                    <Button Text="Edytuj" HeightRequest="35" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditCareTakerQuestionsViewModel}}, Path=OpenEditQuestionEditorCommand}" CommandParameter="{Binding Template}" BackgroundColor="#555555" TextColor="White"/>
                                    <Button Text="Usuń" HeightRequest="35" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditCareTakerQuestionsViewModel}}, Path=DeleteQuestionCommand}" CommandParameter="{Binding Template}" BackgroundColor="#D32F2F" TextColor="White"/>
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsEditorVisible}" Spacing="15">

                <Label FontAttributes="Bold" FontSize="20" Text="{Binding EditorTitle}" HorizontalOptions="Center" Margin="0,0,0,10"/>

                <Label FontAttributes="Bold" Text="Treść pytania:" />
                <Grid Padding="5" BackgroundColor="#2D2D30">
                    <Editor Text="{Binding EditorQuestionText}" Placeholder="np. Jak się dzisiaj czujesz?" HeightRequest="80" TextColor="White" PlaceholderColor="Gray"/>
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label FontAttributes="Bold" Text="Typ pytania:" />
                        <HorizontalStackLayout Spacing="5">
                            <Button Text="Zamk." Command="{Binding SetQuestionTypeCommand}" CommandParameter="Zamknięte" HeightRequest="40" BackgroundColor="#0078D7" TextColor="White" Opacity="{Binding ClosedTypeOpacity}" />
                            <Button Text="Otw." Command="{Binding SetQuestionTypeCommand}" CommandParameter="Otwarte" HeightRequest="40" BackgroundColor="#0078D7" TextColor="White" Opacity="{Binding OpenTypeOpacity}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label FontAttributes="Bold" Text="Tylko losowe?" />
                        <Switch IsToggled="{Binding EditorIsRandomPool}" HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsClosedType}">
                    <Label FontAttributes="Bold" Text="Maks. opcji do zaznaczenia:" />
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Button Text="-" Command="{Binding DecreaseMaxSelectionsCommand}" WidthRequest="45" HeightRequest="45" BackgroundColor="#555555" TextColor="White" FontAttributes="Bold"/>

                        <Label Text="{Binding EditorMaxSelections, StringFormat='{0}'}" VerticalOptions="Center" FontAttributes="Bold" FontSize="20"/>

                        <Button Text="+" Command="{Binding IncreaseMaxSelectionsCommand}" WidthRequest="45" HeightRequest="45" BackgroundColor="#555555" TextColor="White" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsClosedType}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" FontAttributes="Bold" Text="Warianty i punkty:" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="+ Dodaj" Command="{Binding AddOptionCommand}" HeightRequest="35" BackgroundColor="#0078D7" TextColor="White"/>
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding EditorOptions}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:EditorOptionItem">
                                <Grid ColumnDefinitions="*, 70, Auto" ColumnSpacing="10">
                                    <Entry Grid.Column="0" Text="{Binding Text}" Placeholder="Odpowiedź" BackgroundColor="#2D2D30" TextColor="White"/>
                                    <Entry Grid.Column="1" Text="{Binding Points}" Keyboard="Numeric" Placeholder="Pkt" HorizontalTextAlignment="Center" BackgroundColor="#2D2D30" TextColor="White"/>
                                    <Button Grid.Column="2" Text="X" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditCareTakerQuestionsViewModel}}, Path=RemoveOptionCommand}" CommandParameter="{Binding .}" BackgroundColor="#D32F2F" TextColor="White" WidthRequest="45" Padding="0"/>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,20,0,40">
                    <Button Grid.Column="0" Text="Anuluj" Command="{Binding CancelEditCommand}" BackgroundColor="#555555" TextColor="White" HeightRequest="50"/>
                    <Button Grid.Column="1" Text="Zapisz" Command="{Binding SaveQuestionCommand}" BackgroundColor="#4CAF50" TextColor="White" HeightRequest="50" FontAttributes="Bold"/>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>