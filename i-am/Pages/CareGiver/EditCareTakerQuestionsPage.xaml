<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.CareGiver.EditCareTakerQuestionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="Pytania Podopiecznego"
    x:DataType="vm:EditCareTakerQuestionsViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight},
                                      Dark={StaticResource BackgroundDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">

            <VerticalStackLayout Spacing="5">
                <Label
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="Wybierz podopiecznego:"
                    TextColor="{AppThemeBinding Light=Black,
                                                Dark=White}" />

                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                      Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                             Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8">
                    <Grid HeightRequest="50">
                        <Label
                            Margin="15,0,0,0"
                            FontSize="15"
                            HorizontalOptions="Start"
                            Text="{Binding SelectedCareTakerName}"
                            TextColor="{AppThemeBinding Light=Black,
                                                        Dark=White}"
                            VerticalOptions="Center" />
                        <Button
                            BackgroundColor="Transparent"
                            Command="{Binding SelectCareTakerCommand}"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsQuestionsVisible}" Spacing="15">

                <Grid
                    Margin="0,10,0,0"
                    ColumnDefinitions="*, Auto"
                    VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        FontAttributes="Bold"
                        FontSize="16"
                        Text="Lista pytań"
                        TextColor="{AppThemeBinding Light=Black,
                                                    Dark=White}"
                        VerticalOptions="Center" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="{StaticResource Primary}"
                        Command="{Binding OpenNewQuestionEditorCommand}"
                        HeightRequest="40"
                        Text="Dodaj pytanie"
                        TextColor="White" />
                </Grid>

                <ActivityIndicator
                    Margin="0,20,0,0"
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsLoadingQuestions}"
                    IsVisible="{Binding IsLoadingQuestions}"
                    Color="{StaticResource Primary}" />

                <Label
                    Padding="20"
                    HorizontalOptions="Center"
                    IsVisible="{Binding HasNoQuestions}"
                    Text="Brak pytań. Dodaj pierwsze używając przycisku wyżej."
                    TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                Dark={StaticResource Gray400}}" />

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Questions}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:QuestionItemViewModel">

                            <Border
                                Padding="15"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                                  Dark={StaticResource SurfaceDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                         Dark={StaticResource Gray600}}"
                                StrokeShape="RoundRectangle 8">

                                <Grid ColumnDefinitions="*, Auto" RowSpacing="5">
                                    <VerticalStackLayout
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        Spacing="5"
                                        VerticalOptions="Center">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            Text="{Binding Text}"
                                            TextColor="{AppThemeBinding Light=Black,
                                                                        Dark=White}" />

                                        <HorizontalStackLayout Spacing="8">
                                            <Label
                                                FontSize="12"
                                                Text="{Binding TypeText}"
                                                TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                                            Dark={StaticResource Gray400}}" />
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                IsVisible="{Binding IsDaily}"
                                                Text="Codzienne"
                                                TextColor="{StaticResource Primary}" />
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                IsVisible="{Binding IsRandom}"
                                                Text="Losowe z puli"
                                                TextColor="{StaticResource Secondary}" />
                                        </HorizontalStackLayout>

                                        <Label
                                            FontSize="12"
                                            IsVisible="{Binding IsClosed}"
                                            Text="{Binding MaxSelectionsText}"
                                            TextColor="{StaticResource Primary}" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="10"
                                        VerticalOptions="Center">
                                        <Button
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                                              Dark={StaticResource Gray600}}"
                                            Clicked="OnEditQuestionClicked"
                                            CommandParameter="{Binding Template}"
                                            HeightRequest="35"
                                            Text="Edytuj"
                                            TextColor="White" />
                                        <Button
                                            BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight},
                                                                              Dark={StaticResource DangerDark}}"
                                            Clicked="OnDeleteQuestionClicked"
                                            CommandParameter="{Binding Template}"
                                            HeightRequest="35"
                                            Text="Usuń"
                                            TextColor="White" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsEditorVisible}" Spacing="15">

                <Label
                    Margin="0,0,0,10"
                    FontAttributes="Bold"
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="{Binding EditorTitle}"
                    TextColor="{AppThemeBinding Light=Black,
                                                Dark=White}" />

                <Label
                    FontAttributes="Bold"
                    Text="Treść pytania:"
                    TextColor="{AppThemeBinding Light=Black,
                                                Dark=White}" />

                <Border
                    Padding="5"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                      Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                             Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8">
                    <Editor
                        BackgroundColor="Transparent"
                        HeightRequest="80"
                        Placeholder="np. Jak się dzisiaj czujesz?"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource Gray500},
                                                           Dark={StaticResource Gray400}}"
                        Text="{Binding EditorQuestionText}"
                        TextColor="{AppThemeBinding Light=Black,
                                                    Dark=White}" />
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label
                            FontAttributes="Bold"
                            Text="Typ pytania:"
                            TextColor="{AppThemeBinding Light=Black,
                                                        Dark=White}" />
                        <HorizontalStackLayout Spacing="5">
                            <Button
                                BackgroundColor="{StaticResource Primary}"
                                Command="{Binding SetQuestionTypeCommand}"
                                CommandParameter="Zamknięte"
                                HeightRequest="40"
                                Opacity="{Binding ClosedTypeOpacity}"
                                Text="Zamk."
                                TextColor="White" />
                            <Button
                                BackgroundColor="{StaticResource Primary}"
                                Command="{Binding SetQuestionTypeCommand}"
                                CommandParameter="Otwarte"
                                HeightRequest="40"
                                Opacity="{Binding OpenTypeOpacity}"
                                Text="Otw."
                                TextColor="White" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label
                            FontAttributes="Bold"
                            Text="Tylko losowe?"
                            TextColor="{AppThemeBinding Light=Black,
                                                        Dark=White}" />
                        <Switch HorizontalOptions="Start" IsToggled="{Binding EditorIsRandomPool}" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout IsVisible="{Binding IsClosedType}" Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        Text="Maks. liczba odpowiedzi:"
                        TextColor="{AppThemeBinding Light=Black,
                                                    Dark=White}" />
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Button
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                              Dark={StaticResource Gray600}}"
                            Command="{Binding DecreaseMaxSelectionsCommand}"
                            FontAttributes="Bold"
                            HeightRequest="45"
                            Text="-"
                            TextColor="White"
                            WidthRequest="45" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="20"
                            Text="{Binding EditorMaxSelections, StringFormat='{0}'}"
                            TextColor="{AppThemeBinding Light=Black,
                                                        Dark=White}"
                            VerticalOptions="Center" />
                        <Button
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                              Dark={StaticResource Gray600}}"
                            Command="{Binding IncreaseMaxSelectionsCommand}"
                            FontAttributes="Bold"
                            HeightRequest="45"
                            Text="+"
                            TextColor="White"
                            WidthRequest="45" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsClosedType}" Spacing="10">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label
                            Grid.Column="0"
                            FontAttributes="Bold"
                            Text="Odpowiedzi i ich punkty:"
                            TextColor="{AppThemeBinding Light=Black,
                                                        Dark=White}"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            BackgroundColor="{StaticResource Primary}"
                            Command="{Binding AddOptionCommand}"
                            HeightRequest="35"
                            Text="Dodaj"
                            TextColor="White" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding EditorOptions}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:EditorOptionItem">
                                <Grid ColumnDefinitions="*, 70, Auto" ColumnSpacing="10">

                                    <Border
                                        Grid.Column="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                                          Dark={StaticResource SurfaceDark}}"
                                        Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                                 Dark={StaticResource Gray600}}"
                                        StrokeShape="RoundRectangle 8">
                                        <Entry
                                            Margin="10,0"
                                            BackgroundColor="Transparent"
                                            Placeholder="Odpowiedź"
                                            PlaceholderColor="{AppThemeBinding Light={StaticResource Gray500},
                                                                               Dark={StaticResource Gray400}}"
                                            Text="{Binding Text}"
                                            TextColor="{AppThemeBinding Light=Black,
                                                                        Dark=White}" />
                                    </Border>

                                    <Border
                                        Grid.Column="1"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                                          Dark={StaticResource SurfaceDark}}"
                                        Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                                 Dark={StaticResource Gray600}}"
                                        StrokeShape="RoundRectangle 8">
                                        <Entry
                                            Margin="5,0"
                                            BackgroundColor="Transparent"
                                            HorizontalTextAlignment="Center"
                                            Keyboard="Numeric"
                                            Placeholder="Pkt"
                                            PlaceholderColor="{AppThemeBinding Light={StaticResource Gray500},
                                                                               Dark={StaticResource Gray400}}"
                                            Text="{Binding Points}"
                                            TextColor="{AppThemeBinding Light=Black,
                                                                        Dark=White}" />
                                    </Border>

                                    <Button
                                        Grid.Column="2"
                                        Padding="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight},
                                                                          Dark={StaticResource DangerDark}}"
                                        Clicked="OnRemoveOptionClicked"
                                        CommandParameter="{Binding .}"
                                        Text="X"
                                        TextColor="White"
                                        WidthRequest="45" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Grid
                    Margin="0,20,0,40"
                    ColumnDefinitions="*, *"
                    ColumnSpacing="15">
                    <Button
                        Grid.Column="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                          Dark={StaticResource Gray600}}"
                        Command="{Binding CancelEditCommand}"
                        HeightRequest="50"
                        Text="Anuluj"
                        TextColor="White" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="{StaticResource Secondary}"
                        Command="{Binding SaveQuestionCommand}"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Text="Zapisz"
                        TextColor="White" />
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>