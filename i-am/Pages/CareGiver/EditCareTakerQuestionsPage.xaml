<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.CareGiver.EditCareTakerQuestionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="Zarządzaj Pytaniami"
    x:DataType="vm:EditCareTakerQuestionsViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight},
                                      Dark={StaticResource BackgroundDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">

            <VerticalStackLayout IsVisible="{Binding IsQuestionsVisible}" Spacing="15">
                <Grid
                    Margin="0,10,0,0"
                    ColumnDefinitions="*, Auto"
                    VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        FontAttributes="Bold"
                        FontSize="16"
                        Text="{Binding SelectedCareTaker.Name, StringFormat='Pytania dla: {0}'}"
                        VerticalOptions="Center" />
                    <Button
                        Grid.Column="1"
                        Command="{Binding OpenNewQuestionEditorCommand}"
                        HeightRequest="40"
                        Text="Dodaj" />
                </Grid>

                <ActivityIndicator
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsLoadingQuestions}"
                    IsVisible="{Binding IsLoadingQuestions}" />

                <Label
                    Padding="20"
                    HorizontalOptions="Center"
                    IsVisible="{Binding HasNoQuestions}"
                    Style="{StaticResource SubtitleLabelStyle}"
                    Text="Brak pytań dla tego podopiecznego." />

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Questions}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:QuestionItemViewModel">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <Grid ColumnDefinitions="*, Auto" RowSpacing="5">
                                    <VerticalStackLayout
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        Spacing="5"
                                        VerticalOptions="Center">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            Text="{Binding Text}" />

                                        <HorizontalStackLayout Spacing="8">
                                            <Label
                                                FontSize="12"
                                                Style="{StaticResource SubtitleLabelStyle}"
                                                Text="{Binding TypeText}" />
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                IsVisible="{Binding IsDaily}"
                                                Text="Codzienne"
                                                TextColor="{AppThemeBinding Light={StaticResource Primary},
                                                                            Dark={StaticResource PrimaryDark}}" />
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                IsVisible="{Binding IsRandom}"
                                                Text="Losowe"
                                                TextColor="{AppThemeBinding Light={StaticResource SuccessLight},
                                                                            Dark={StaticResource SuccessDark}}" />
                                        </HorizontalStackLayout>

                                        <Label
                                            FontSize="12"
                                            IsVisible="{Binding IsClosed}"
                                            Text="{Binding MaxSelectionsText}"
                                            TextColor="{AppThemeBinding Light={StaticResource Primary},
                                                                        Dark={StaticResource PrimaryDark}}" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="10"
                                        VerticalOptions="Center">
                                        <Button
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                                              Dark={StaticResource Gray600}}"
                                            Clicked="OnEditQuestionClicked"
                                            CommandParameter="{Binding Template}"
                                            HeightRequest="35"
                                            Text="Edytuj" />
                                        <Button
                                            Clicked="OnDeleteQuestionClicked"
                                            CommandParameter="{Binding Template}"
                                            HeightRequest="35"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Text="Usuń" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsEditorVisible}" Spacing="15">
                <Label
                    FontAttributes="Bold"
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="{Binding EditorTitle}" />

                <Label Style="{StaticResource FormLabelStyle}" Text="Treść pytania:" />
                <Border Style="{StaticResource InputBorderStyle}">
                    <Editor
                        AutoSize="TextChanges"
                        BackgroundColor="Transparent"
                        MinimumHeightRequest="80"
                        Text="{Binding EditorQuestionText}" />
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Style="{StaticResource FormLabelStyle}" Text="Typ pytania:" />
                        <HorizontalStackLayout Spacing="5">
                            <Button
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary},
                                                                  Dark={StaticResource PrimaryDark}}"
                                Command="{Binding SetQuestionTypeCommand}"
                                CommandParameter="Zamknięte"
                                HeightRequest="40"
                                Opacity="{Binding ClosedTypeOpacity}"
                                Text="Zamk." />
                            <Button
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary},
                                                                  Dark={StaticResource PrimaryDark}}"
                                Command="{Binding SetQuestionTypeCommand}"
                                CommandParameter="Otwarte"
                                HeightRequest="40"
                                Opacity="{Binding OpenTypeOpacity}"
                                Text="Otw." />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Style="{StaticResource FormLabelStyle}" Text="Losowe?" />
                        <Switch HorizontalOptions="Start" IsToggled="{Binding EditorIsRandomPool}" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout IsVisible="{Binding IsClosedType}" Spacing="10">
                    <Label Style="{StaticResource FormLabelStyle}" Text="Maks. liczba odpowiedzi:" />
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Button
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                              Dark={StaticResource Gray600}}"
                            Command="{Binding DecreaseMaxSelectionsCommand}"
                            FontAttributes="Bold"
                            HeightRequest="45"
                            Text="-"
                            WidthRequest="45" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="20"
                            Text="{Binding EditorMaxSelections, StringFormat='{0}'}"
                            VerticalOptions="Center" />
                        <Button
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                              Dark={StaticResource Gray600}}"
                            Command="{Binding IncreaseMaxSelectionsCommand}"
                            FontAttributes="Bold"
                            HeightRequest="45"
                            Text="+"
                            WidthRequest="45" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsClosedType}" Spacing="10">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label
                            Grid.Column="0"
                            Style="{StaticResource FormLabelStyle}"
                            Text="Odpowiedzi i punkty:" />
                        <Button
                            Grid.Column="1"
                            Command="{Binding AddOptionCommand}"
                            HeightRequest="35"
                            Text="Dodaj" />
                    </Grid>
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding EditorOptions}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:EditorOptionItem">
                                <Grid ColumnDefinitions="*, 70, Auto" ColumnSpacing="10">
                                    <Border Grid.Column="0" Style="{StaticResource CompactInputBorderStyle}">
                                        <Entry
                                            Margin="5,0"
                                            BackgroundColor="Transparent"
                                            Placeholder="Odp"
                                            Text="{Binding Text}" />
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CompactInputBorderStyle}">
                                        <Entry
                                            Margin="5,0"
                                            BackgroundColor="Transparent"
                                            Keyboard="Numeric"
                                            Placeholder="Pkt"
                                            Text="{Binding Points}" />
                                    </Border>
                                    <Button
                                        Grid.Column="2"
                                        Clicked="OnRemoveOptionClicked"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Text="X"
                                        WidthRequest="45" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Grid
                    Margin="0,20,0,40"
                    ColumnDefinitions="*, *"
                    ColumnSpacing="15">
                    <Button
                        Grid.Column="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                          Dark={StaticResource Gray600}}"
                        Command="{Binding CancelEditCommand}"
                        HeightRequest="50"
                        Text="Anuluj" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SuccessLight},
                                                          Dark={StaticResource SuccessDark}}"
                        Command="{Binding SaveQuestionCommand}"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Text="Zapisz" />
                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>