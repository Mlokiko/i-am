<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.CareGiver.EditCareTakerQuestionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="Pytania Podopiecznego"
    x:DataType="vm:EditCareTakerQuestionsViewModel">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Label
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="1. Wybierz podopiecznego:" />
                <Border
                    Padding="10,0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                      Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                             Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 12">
                    <Picker
                        Title="Kliknij, aby wybrać..."
                        ItemDisplayBinding="{Binding Name}"
                        ItemsSource="{Binding CareTakers}"
                        SelectedItem="{Binding SelectedCareTaker}" />
                </Border>

                <VerticalStackLayout IsVisible="{Binding IsQuestionsVisible}" Spacing="15">

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label
                            Grid.Column="0"
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Aktualne Pytania"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Command="{Binding OpenNewQuestionEditorCommand}"
                            CornerRadius="6"
                            HeightRequest="35"
                            Text="+ Dodaj" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Questions}">
                        <CollectionView.EmptyView>
                            <Label
                                Padding="20"
                                HorizontalOptions="Center"
                                Text="Ten podopieczny nie ma jeszcze pytań."
                                TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                            Dark={StaticResource Gray400}}" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:QuestionTemplate">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="15"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                                      Dark={StaticResource SurfaceDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                             Dark={StaticResource Gray600}}"
                                    StrokeShape="RoundRectangle 8">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <VerticalStackLayout
                                            Grid.Column="0"
                                            Spacing="5"
                                            VerticalOptions="Center">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="15"
                                                Text="{Binding Text}" />

                                            <HorizontalStackLayout Spacing="8">
                                                <Label FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}">
                                                    <Label.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding Type}"
                                                            TargetType="Label"
                                                            Value="Open">
                                                            <Setter Property="Text" Value="Format: Otwarte |" />
                                                        </DataTrigger>
                                                        <DataTrigger
                                                            Binding="{Binding Type}"
                                                            TargetType="Label"
                                                            Value="Closed">
                                                            <Setter Property="Text" Value="Format: Zamknięte |" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>

                                                <Label FontAttributes="Bold" FontSize="12">
                                                    <Label.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding IsRandomPool}"
                                                            TargetType="Label"
                                                            Value="False">
                                                            <Setter Property="Text" Value="Codzienne" />
                                                            <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                                        </DataTrigger>
                                                        <DataTrigger
                                                            Binding="{Binding IsRandomPool}"
                                                            TargetType="Label"
                                                            Value="True">
                                                            <Setter Property="Text" Value="Losowe z puli" />
                                                            <Setter Property="TextColor" Value="{StaticResource Secondary}" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </HorizontalStackLayout>

                                            <Label
                                                FontSize="12"
                                                Text="{Binding MaxSelections, StringFormat='Max. odpowiedzi: {0}'}"
                                                TextColor="{StaticResource Primary}">
                                                <Label.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding Type}"
                                                        TargetType="Label"
                                                        Value="Open">
                                                        <Setter Property="IsVisible" Value="False" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </VerticalStackLayout>

                                        <HorizontalStackLayout
                                            Grid.Column="1"
                                            Spacing="10"
                                            VerticalOptions="Center">
                                            <Button
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditCareTakerQuestionsViewModel}}, Path=OpenEditQuestionEditorCommand}"
                                                CommandParameter="{Binding .}"
                                                HeightRequest="35"
                                                Text="Edytuj" />
                                            <Button
                                                BackgroundColor="{StaticResource Danger}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditCareTakerQuestionsViewModel}}, Path=DeleteQuestionCommand}"
                                                CommandParameter="{Binding .}"
                                                HeightRequest="35"
                                                Text="X"
                                                WidthRequest="40" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <BoxView
                    HeightRequest="450"
                    IsVisible="{Binding IsEditorVisible}"
                    Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <Border
            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                              Dark={StaticResource SurfaceDark}}"
            IsVisible="{Binding IsEditorVisible}"
            Shadow="{Shadow Brush=Black,
                            Offset='0,-5',
                            Radius=15,
                            Opacity=0.1}"
            Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                     Dark={StaticResource Gray600}}"
            StrokeShape="RoundRectangle 20,20,0,0"
            VerticalOptions="End">

            <VerticalStackLayout Padding="20" Spacing="15">
                <Label
                    FontAttributes="Bold"
                    FontSize="18"
                    HorizontalOptions="Center"
                    Text="{Binding EditorTitle}" />

                <Label FontAttributes="Bold" Text="Treść pytania:" />
                <Border Padding="10,0" StrokeShape="RoundRectangle 8">
                    <Entry Placeholder="np. Jak się dzisiaj czujesz?" Text="{Binding EditorQuestionText}" />
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0">
                        <Label FontAttributes="Bold" Text="Typ pytania:" />
                        <Border Padding="10,0" StrokeShape="RoundRectangle 8">
                            <Picker ItemsSource="{Binding AvailableTypes}" SelectedItem="{Binding EditorQuestionType}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1">
                        <Label FontAttributes="Bold" Text="Tylko losowe z puli?" />
                        <Switch
                            Margin="0,5,0,0"
                            HorizontalOptions="Start"
                            IsToggled="{Binding EditorIsRandomPool}" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="5">
                    <VerticalStackLayout.Triggers>
                        <DataTrigger
                            Binding="{Binding EditorQuestionType}"
                            TargetType="VerticalStackLayout"
                            Value="Otwarte">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>
                    <Label FontAttributes="Bold" Text="Maksymalna liczba opcji do zaznaczenia:" />
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Stepper
                            Increment="1"
                            Maximum="10"
                            Minimum="1"
                            Value="{Binding EditorMaxSelections}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="{Binding EditorMaxSelections, StringFormat='Wybrano: {0}'}"
                            TextColor="{StaticResource Primary}"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <VerticalStackLayout.Triggers>
                        <DataTrigger
                            Binding="{Binding EditorQuestionType}"
                            TargetType="VerticalStackLayout"
                            Value="Otwarte">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label
                            Grid.Column="0"
                            FontAttributes="Bold"
                            Text="Warianty i punkty:"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Padding="10,0"
                            Command="{Binding AddOptionCommand}"
                            HeightRequest="30"
                            Text="+ Wariant" />
                    </Grid>

                    <ScrollView MaximumHeightRequest="150">
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding EditorOptions}" Spacing="5">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:QuestionOption">
                                    <Grid ColumnDefinitions="*, 80, Auto" ColumnSpacing="10">
                                        <Entry
                                            Grid.Column="0"
                                            Placeholder="Odpowiedź"
                                            Text="{Binding Text}" />
                                        <Entry
                                            Grid.Column="1"
                                            HorizontalTextAlignment="Center"
                                            Keyboard="Numeric"
                                            Placeholder="Pkt"
                                            Text="{Binding Points}" />
                                        <Button
                                            Grid.Column="2"
                                            Padding="0"
                                            BackgroundColor="{StaticResource Danger}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditCareTakerQuestionsViewModel}}, Path=RemoveOptionCommand}"
                                            CommandParameter="{Binding .}"
                                            Text="X"
                                            WidthRequest="40" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>

                <Grid
                    Margin="0,5,0,0"
                    ColumnDefinitions="*, *"
                    ColumnSpacing="15">
                    <Button
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Gray500}"
                        Command="{Binding CancelEditCommand}"
                        Text="Anuluj" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="{StaticResource Success}"
                        Command="{Binding SaveQuestionCommand}"
                        Text="Zapisz" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
