<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.CareGiver.EditCareTakerQuestionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    x:DataType="vm:EditCareTakerQuestionsViewModel"
    Title="Pytania Podopiecznego"
    BackgroundColor="{Binding PageBgColor}">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">

            <VerticalStackLayout Spacing="5">
                <Label FontAttributes="Bold" FontSize="16" Text="1. Wybierz podopiecznego:" TextColor="{Binding TextColor}" />

                <Grid HeightRequest="50" BackgroundColor="{Binding CardBgColor}">
                    <BoxView Color="{Binding DividerColor}" Opacity="0.2" CornerRadius="8" />
                    <Label Text="{Binding SelectedCareTakerName}" HorizontalOptions="Start" VerticalOptions="Center" Margin="15,0,0,0" FontSize="16" TextColor="{Binding TextColor}" />
                    <Button Command="{Binding SelectCareTakerCommand}" BackgroundColor="Transparent" HorizontalOptions="Fill" VerticalOptions="Fill" />
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsQuestionsVisible}">

                <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center" Margin="0,10,0,0">
                    <Label Grid.Column="0" FontAttributes="Bold" FontSize="16" Text="Aktualne Pytania" VerticalOptions="Center" TextColor="{Binding TextColor}" />
                    <Button Grid.Column="1" Command="{Binding OpenNewQuestionEditorCommand}" Text="+ Dodaj Pytanie" BackgroundColor="{Binding PrimaryColor}" TextColor="White" HeightRequest="40" />
                </Grid>

                <Label Text="Ładowanie pytań..." IsVisible="{Binding IsLoadingQuestions}" TextColor="{Binding PrimaryColor}" HorizontalOptions="Center" Margin="0,20,0,0" FontAttributes="Bold"/>

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Questions}" Spacing="10">
                    <BindableLayout.EmptyView>
                        <Label HorizontalOptions="Center" Padding="20" Text="Brak pytań. Dodaj pierwsze używając przycisku wyżej." TextColor="{Binding SubTextColor}" />
                    </BindableLayout.EmptyView>

                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:QuestionItemViewModel">
                            <Grid Padding="15" ColumnDefinitions="*, Auto" BackgroundColor="{Binding CardBgColor}" RowSpacing="5">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="5" Margin="0,0,10,0">
                                    <Label FontAttributes="Bold" FontSize="15" Text="{Binding Text}" TextColor="{Binding TxtColor}"/>

                                    <HorizontalStackLayout Spacing="8">
                                        <Label FontSize="12" TextColor="{Binding SubTxtColor}" Text="{Binding TypeText}" />
                                        <Label FontSize="12" TextColor="{Binding PrimaryColor}" FontAttributes="Bold" Text="Codzienne" IsVisible="{Binding IsDaily}"/>
                                        <Label FontSize="12" TextColor="{Binding SecondaryColor}" FontAttributes="Bold" Text="Losowe z puli" IsVisible="{Binding IsRandom}"/>
                                    </HorizontalStackLayout>

                                    <Label FontSize="12" TextColor="{Binding PrimaryColor}" Text="{Binding MaxSelectionsText}" IsVisible="{Binding IsClosed}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                                    <Button Text="Edytuj" HeightRequest="35" Clicked="OnEditQuestionClicked" CommandParameter="{Binding Template}" BackgroundColor="{Binding EditBtnColor}" TextColor="White"/>
                                    <Button Text="Usuń" HeightRequest="35" Clicked="OnDeleteQuestionClicked" CommandParameter="{Binding Template}" BackgroundColor="{Binding DangerBtnColor}" TextColor="White"/>
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsEditorVisible}">

                <Label FontAttributes="Bold" FontSize="20" Text="{Binding EditorTitle}" HorizontalOptions="Center" Margin="0,0,0,10" TextColor="{Binding TextColor}"/>

                <Label FontAttributes="Bold" Text="Treść pytania:" TextColor="{Binding TextColor}" />
                <Grid BackgroundColor="{Binding CardBgColor}">
                    <Editor Text="{Binding EditorQuestionText}" Placeholder="np. Jak się dzisiaj czujesz?" HeightRequest="80" Margin="10,5" TextColor="{Binding TextColor}" PlaceholderColor="{Binding SubTextColor}"/>
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label FontAttributes="Bold" Text="Typ pytania:" TextColor="{Binding TextColor}" />
                        <HorizontalStackLayout Spacing="5">
                            <Button Text="Zamk." Command="{Binding SetQuestionTypeCommand}" CommandParameter="Zamknięte" HeightRequest="40" BackgroundColor="{Binding PrimaryColor}" TextColor="White" Opacity="{Binding ClosedTypeOpacity}" />
                            <Button Text="Otw." Command="{Binding SetQuestionTypeCommand}" CommandParameter="Otwarte" HeightRequest="40" BackgroundColor="{Binding PrimaryColor}" TextColor="White" Opacity="{Binding OpenTypeOpacity}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label FontAttributes="Bold" Text="Tylko losowe?" TextColor="{Binding TextColor}" />
                        <Switch IsToggled="{Binding EditorIsRandomPool}" HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsClosedType}">
                    <Label FontAttributes="Bold" Text="Maks. opcji do zaznaczenia:" TextColor="{Binding TextColor}"/>
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Button Text="-" Command="{Binding DecreaseMaxSelectionsCommand}" WidthRequest="45" HeightRequest="45" BackgroundColor="{Binding CancelBtnColor}" TextColor="White" FontAttributes="Bold"/>
                        <Label Text="{Binding EditorMaxSelections, StringFormat='{0}'}" VerticalOptions="Center" FontAttributes="Bold" FontSize="20" TextColor="{Binding TextColor}"/>
                        <Button Text="+" Command="{Binding IncreaseMaxSelectionsCommand}" WidthRequest="45" HeightRequest="45" BackgroundColor="{Binding CancelBtnColor}" TextColor="White" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsClosedType}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" FontAttributes="Bold" Text="Warianty i punkty:" VerticalOptions="Center" TextColor="{Binding TextColor}"/>
                        <Button Grid.Column="1" Text="+ Dodaj" Command="{Binding AddOptionCommand}" HeightRequest="35" BackgroundColor="{Binding PrimaryColor}" TextColor="White"/>
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding EditorOptions}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:EditorOptionItem">
                                <Grid ColumnDefinitions="*, 70, Auto" ColumnSpacing="10">

                                    <Grid Grid.Column="0" BackgroundColor="{Binding CardBgColor}">
                                        <Entry Text="{Binding Text}" Placeholder="Odpowiedź" Margin="10,0" TextColor="{Binding TxtColor}" PlaceholderColor="{Binding PlaceholderColor}"/>
                                    </Grid>
                                    <Grid Grid.Column="1" BackgroundColor="{Binding CardBgColor}">
                                        <Entry Text="{Binding Points}" Keyboard="Numeric" Placeholder="Pkt" HorizontalTextAlignment="Center" Margin="5,0" TextColor="{Binding TxtColor}" PlaceholderColor="{Binding PlaceholderColor}"/>
                                    </Grid>

                                    <Button Grid.Column="2" Text="X" Clicked="OnRemoveOptionClicked" CommandParameter="{Binding .}" BackgroundColor="{Binding DangerColor}" TextColor="White" WidthRequest="45" Padding="0"/>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,20,0,40">
                    <Button Grid.Column="0" Text="Anuluj" Command="{Binding CancelEditCommand}" BackgroundColor="{Binding CancelBtnColor}" TextColor="White" HeightRequest="50"/>
                    <Button Grid.Column="1" Text="Zapisz" Command="{Binding SaveQuestionCommand}" BackgroundColor="{Binding SuccessColor}" TextColor="White" HeightRequest="50" FontAttributes="Bold"/>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>