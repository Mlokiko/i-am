<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.CareGiver.ManageCareTakersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="Zarządzaj Podopiecznymi"
    x:DataType="vm:ManageCareTakersViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Border
                Padding="15"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Zaproś Podopiecznego"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDarkText}}" />
                    <Entry
                        Text="{Binding InviteEmail}"
                        ClearButtonVisibility="WhileEditing"
                        Keyboard="Email"
                        Placeholder="Adres email podopiecznego" />
                    <Button
                        Command="{Binding InviteCommand}"
                        Text="Wyślij Zaproszenie" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10">
                <Label FontAttributes="Bold" FontSize="16" Text="Aktywne zaproszenia" />
                <CollectionView ItemsSource="{Binding AllInvitations}">
                    <CollectionView.EmptyView>
                        <Label Padding="20" HorizontalOptions="Center" Text="Brak aktywnych zaproszeń." 
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Invitation">
                            <Border Margin="0,0,0,10" Padding="12" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label FontAttributes="Bold" FontSize="14">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSentByMe}" Value="True">
                                                    <Setter Property="Text" Value="{Binding ReceiverEmail, StringFormat='Do: {0}'}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSentByMe}" Value="False">
                                                    <Setter Property="Text" Value="{Binding SenderName, StringFormat='Od: {0}'}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label FontSize="12">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Pending">
                                                    <Setter Property="Text" Value="Oczekujące..." />
                                                    <Setter Property="TextColor" Value="{StaticResource Warning}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Rejected">
                                                    <Setter Property="Text" Value="Odrzucone" />
                                                    <Setter Property="TextColor" Value="{StaticResource Danger}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1" Text="Usuń" HeightRequest="35" CornerRadius="6" TextColor="White"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManageCareTakersViewModel}}, Path=CancelInvitationCommand}"
                                            CommandParameter="{Binding .}"
                                            IsVisible="{Binding IsSentByMe}" VerticalOptions="Center" />

                                    <HorizontalStackLayout Grid.Column="1" Spacing="10">
                                        <HorizontalStackLayout.Triggers>
                                            <DataTrigger TargetType="HorizontalStackLayout" Binding="{Binding IsSentByMe}" Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </HorizontalStackLayout.Triggers>

                                        <Button Text="Akceptuj" HeightRequest="35" CornerRadius="6" TextColor="White"
                                                BackgroundColor="{StaticResource Success}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManageCareTakersViewModel}}, Path=AcceptCommand}"
                                                CommandParameter="{Binding .}" />

                                        <Button Text="Odrzuć" HeightRequest="35" CornerRadius="6" TextColor="White"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManageCareTakersViewModel}}, Path=RejectCommand}"
                                                CommandParameter="{Binding .}" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label FontAttributes="Bold" FontSize="16" Text="Moi Podopieczni" />
                <CollectionView ItemsSource="{Binding CareTakers}">
                    <CollectionView.EmptyView>
                        <Label Padding="20" HorizontalOptions="Center" Text="Nie masz jeszcze żadnych podopiecznych." 
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:User">
                            <Border Margin="0,0,0,10" Padding="15" StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label FontAttributes="Bold" FontSize="16" Text="{Binding Name}" />
                                        <Label FontSize="13" Text="{Binding Email}" 
                                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1" Text="Usuń" HeightRequest="35" CornerRadius="6" TextColor="White"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManageCareTakersViewModel}}, Path=RemoveCareTakerCommand}"
                                            CommandParameter="{Binding .}" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>