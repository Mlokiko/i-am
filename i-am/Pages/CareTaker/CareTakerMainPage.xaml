<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.CareTaker.CareTakerMainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    xmlns:local="clr-namespace:i_am.Resources.Strings"
    x:DataType="vm:CareTakerMainViewModel">

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="30"
            HorizontalOptions="Center"
            Text="I AM"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <Grid Padding="20">
        <VerticalStackLayout
            HorizontalOptions="Fill"
            Spacing="25"
            VerticalOptions="Center">

            <ScrollView>
                <VerticalStackLayout Spacing="10">
                    <Button Command="{Binding GoToNotificationsCommand}" Text="{Binding Source={x:Static local:AppStrings.CareTaker_Notifications}}" />
                    <Button Command="{Binding GoToDailyActivityCommand}" Text="{Binding Source={x:Static local:AppStrings.CareTaker_DailyActivity}}" />
                    <Button Command="{Binding GoToCalendarCommand}" Text="{Binding Source={x:Static local:AppStrings.CareTaker_Calendar}}" />
                    <Button Command="{Binding GoToManageCareGiversCommand}" Text="{Binding Source={x:Static local:AppStrings.CareTaker_ManageCareGivers}}" />
                    <Button Command="{Binding GoToSettingsCommand}" Text="{Binding Source={x:Static local:AppStrings.CareTaker_Settings}}" />
                    <Button Command="{Binding GoToManageAccountCommand}" Text="{Binding Source={x:Static local:AppStrings.CareTaker_ManageAccount}}" />
                </VerticalStackLayout>
            </ScrollView>

            <VerticalStackLayout>
                <Button
                    Margin="0,10,0,0"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource DangerButtonStyle}"
                    Text="{Binding Source={x:Static local:AppStrings.CareTaker_Logout}}" />
                <Label
                    Padding="20"
                    HorizontalOptions="Center"
                    Style="{StaticResource SubtitleLabelStyle}"
                    Text="{Binding Source={x:Static local:AppStrings.CareTaker_EmergencyInfo}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToInformationCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>