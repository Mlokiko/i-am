<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="i_am.Pages.CareTaker.CareTakerMainPage">

    <Shell.TitleView>
        <Label Text="Panel Główny" 
               TextColor="White" 
               FontSize="30" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               VerticalOptions="Center" />
    </Shell.TitleView>

    <VerticalStackLayout 
        VerticalOptions="Fill" 
        HorizontalOptions="Fill"
        Spacing="15"
        Padding="20">

        <!-- Zawartość -->
        <ScrollView>
            <VerticalStackLayout Spacing="10">
                <Button 
                    x:Name="NotificationsButton"
                    Text="Powiadomienia"
                    Clicked="OnNotificationsButtonClicked" 
                    HorizontalOptions="Fill"/>

                <Button 
                    x:Name="DailyActivityButton"
                    Text="Codzienna aktywność"
                    Clicked="OnDailyActivityButtonClicked" 
                    HorizontalOptions="Fill" />

                <Button 
                    x:Name="MyCalendarButton"
                    Text="Kalendarz"
                    Clicked="OnCalendarButtonClicked" 
                    HorizontalOptions="Fill" />

                <Button 
                    x:Name="ManageCareGiversButton"
                    Text="Zarzadzaj Opiekunami"
                    Clicked="OnManageCaregiversButtonClicked" 
                    HorizontalOptions="Fill" />

                <Button 
                    x:Name="ManageAccountButton"
                    Text="Zarządzaj swoim kontem"
                    Clicked="OnManageAccountButtonClicked" 
                    HorizontalOptions="Fill" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Stópka -->
        <VerticalStackLayout>
            <Button x:Name="LogoutButton"
                    Text="Wyloguj się"
                    Clicked="OnLogoutButtonClicked" 
                    HorizontalOptions="Fill"
                    Style="{StaticResource DangerButtonStyle}"
                    Margin="0,10,0,0" />

            <Label 
                Text="Informacje alarmowe"
                FontSize="12"
                Padding="20"
                TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" 
                HorizontalOptions="Center" >
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAlarmInformationTapped" />
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentPage>
