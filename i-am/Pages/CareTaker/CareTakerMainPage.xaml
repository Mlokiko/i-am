<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="i_am.Pages.CareTaker.CareTakerMainPage"
             Title="CareTakerMainPage"
             Shell.NavBarIsVisible="False">
    <VerticalStackLayout 
        VerticalOptions="Fill" 
        HorizontalOptions="Fill"
        Spacing="15"
        Padding="20">

        <!-- Nagłówek -->
        <VerticalStackLayout 
            Spacing="5"
            Margin="0,10,0,20">
            <Label 
                Text="Panel Główny"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Zawartość -->
        <ScrollView>
            <VerticalStackLayout Spacing="10">
                <Button 
                    x:Name="NotificationsButton"
                    Text="Powiadomienia"
                    Clicked="OnNotificationsButtonClicked" 
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFA500" />

                <Button 
                    x:Name="DailyActivityButton"
                    Text="Codzienna aktywność"
                    Clicked="OnDailyActivityButtonClicked" 
                    HorizontalOptions="Fill" />

                <Button 
                    x:Name="MyCalendarButton"
                    Text="Kalendarz"
                    Clicked="OnCalendarButtonClicked" 
                    HorizontalOptions="Fill" />

                <Button 
                    x:Name="ManageCareGiversButton"
                    Text="Zarzadzaj Opiekunami"
                    Clicked="OnManageCaregiversButtonClicked" 
                    HorizontalOptions="Fill" />

                <Button 
                    x:Name="ManageAccountButton"
                    Text="Zarządzaj swoim kontem"
                    Clicked="OnManageAccountButtonClicked" 
                    HorizontalOptions="Fill" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Stópka -->
        <VerticalStackLayout>
            <Button 
                x:Name="LogoutButton"
                Text="Wyloguj sie"
                Clicked="OnLogoutButtonClicked" 
                HorizontalOptions="Fill"
                BackgroundColor="#d32f2f"
                TextColor="White"
                Margin="0,10,0,0" />

            <Label 
                Text="Informacje alarmowe"
                FontSize="12"
                Padding="20"
                TextColor="Grey" 
                HorizontalOptions="Center" >
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAlarmInformationTapped" />
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentPage>
