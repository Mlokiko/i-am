<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.CareTaker.DailyActivityPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:i_am.ViewModels"
    Title="Codzienna Ankieta"
    x:DataType="viewmodels:DailyActivityViewModel">

    <Grid>
        <ActivityIndicator
            HorizontalOptions="Center"
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            VerticalOptions="Center"
            Color="{StaticResource Primary}" />

        <VerticalStackLayout
            Padding="30"
            HorizontalOptions="Center"
            IsVisible="{Binding HasAlreadySubmitted}"
            Spacing="20"
            VerticalOptions="Center">
            <Label
                FontSize="60"
                HorizontalOptions="Center"
                Text="🎉" />
            <Label
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="Dziękujemy!" />
            <Label
                FontSize="16"
                HorizontalTextAlignment="Center"
                Text="Twój dzisiejszy raport został już wysłany do opiekuna. Wróć tu jutro!"
                TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                            Dark={StaticResource Gray400}}" />
        </VerticalStackLayout>

        <ScrollView>
            <ScrollView.Triggers>
                <DataTrigger
                    Binding="{Binding HasAlreadySubmitted}"
                    TargetType="ScrollView"
                    Value="True">
                    <Setter Property="IsVisible" Value="False" />
                </DataTrigger>
                <DataTrigger
                    Binding="{Binding IsLoading}"
                    TargetType="ScrollView"
                    Value="True">
                    <Setter Property="IsVisible" Value="False" />
                </DataTrigger>
            </ScrollView.Triggers>

            <VerticalStackLayout Padding="20" Spacing="20">
                <Label
                    Margin="0,0,0,10"
                    FontAttributes="Bold"
                    FontSize="22"
                    HorizontalOptions="Center"
                    Text="Jak się dzisiaj masz?" />

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding FormItems}" Spacing="25">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:AnswerFormItem">
                            <VerticalStackLayout Spacing="10">

                                <Label
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    Text="{Binding Question.Text}"
                                    TextColor="{Binding TitleColor}" />
                                <Label
                                    Margin="0,-5,0,5"
                                    FontAttributes="Italic"
                                    FontSize="12"
                                    IsVisible="{Binding IsClosed}"
                                    Text="{Binding SelectionHint}"
                                    TextColor="{Binding HintColor}" />

                                <FlexLayout
                                    AlignContent="Start"
                                    AlignItems="Start"
                                    BindableLayout.ItemsSource="{Binding SelectableOptions}"
                                    Direction="Row"
                                    IsVisible="{Binding IsClosed}"
                                    Wrap="Wrap">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:OptionItem">
                                            <Border
                                                Margin="0,0,10,10"
                                                Padding="15,10"
                                                BackgroundColor="{Binding BgColor}"
                                                Stroke="{Binding BorderColor}"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="2">

                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                </Border.GestureRecognizers>

                                                <Label
                                                    FontAttributes="{Binding TextFontAttributes}"
                                                    Text="{Binding Option.Text}"
                                                    TextColor="{Binding TxtColor}" />
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>

                                <Border
                                    Padding="10"
                                    BackgroundColor="{Binding EditorBgColor}"
                                    IsVisible="{Binding IsOpen}"
                                    Stroke="{Binding EditorBorderColor}"
                                    StrokeShape="RoundRectangle 8">
                                    <Editor
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="80"
                                        Placeholder="Twoja odpowiedź..."
                                        Text="{Binding OpenText}"
                                        TextColor="{Binding TitleColor}" />
                                </Border>

                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button
                    Margin="0,20,0,40"
                    BackgroundColor="{StaticResource Primary}"
                    Command="{Binding SubmitAnswersCommand}"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Wyślij Raport"
                    TextColor="White" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>