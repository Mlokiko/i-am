<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:i_am.Models"
             x:Class="i_am.Pages.CareTaker.ManageCareGiversPage"
             Title="Zarządzaj Opiekunami">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Frame CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Zaproś nowego opiekuna" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDarkText}}"/>
                    <Entry x:Name="EmailEntry" Placeholder="Adres email opiekuna" Keyboard="Email" ClearButtonVisibility="WhileEditing"/>
                    <Button Text="Wyślij Zaproszenie" Clicked="OnSendInviteClicked" BackgroundColor="{StaticResource Tertiary}" TextColor="White" CornerRadius="8" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout Spacing="10">
                <Label Text="Zaproszenia" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDarkText}}"/>

                <CollectionView ItemsSource="{Binding AllInvitations}">
                    <CollectionView.EmptyView>
                        <Label Text="Brak oczekujących zaproszeń." FontSize="14" TextColor="Gray" FontAttributes="Italic" Margin="0,5,0,10"/>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Invitation">
                            <Frame CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                <Grid>

                                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto, Auto" RowSpacing="10" ColumnSpacing="10" IsVisible="False">
                                        <Grid.Triggers>
                                            <DataTrigger TargetType="Grid" Binding="{Binding IsSentByMe}" Value="False">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </Grid.Triggers>

                                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                                            <Label Text="{Binding SenderName}" FontSize="16" FontAttributes="Bold" />
                                            <Label Text="Chce zostać Twoim opiekunem." FontSize="12" TextColor="Gray" />
                                        </VerticalStackLayout>

                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" HorizontalOptions="End" Spacing="10">
                                            <HorizontalStackLayout.Triggers>
                                                <DataTrigger TargetType="HorizontalStackLayout" Binding="{Binding Status}" Value="Rejected">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </HorizontalStackLayout.Triggers>
                                            <Button Text="Odrzuć" BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" TextColor="White" Clicked="OnRejectClicked" CommandParameter="{Binding .}" HeightRequest="35" CornerRadius="6"/>
                                            <Button Text="Akceptuj" BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDarkText}}" TextColor="White" Clicked="OnAcceptClicked" CommandParameter="{Binding .}" HeightRequest="35" CornerRadius="6" FontAttributes="Bold"/>
                                        </HorizontalStackLayout>

                                        <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Text="Odrzuciłeś zaproszenie." TextColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" IsVisible="False">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Rejected">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>


                                    <Grid ColumnDefinitions="*, Auto" IsVisible="False">
                                        <Grid.Triggers>
                                            <DataTrigger TargetType="Grid" Binding="{Binding IsSentByMe}" Value="True">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </Grid.Triggers>

                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                            <Label Text="{Binding ReceiverEmail, StringFormat='Wysłano do: {0}'}" FontSize="14" FontAttributes="Bold"/>
                                            <Label Text="Czeka na akceptację..." FontSize="14" TextColor="DarkOrange">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Rejected">
                                                        <Setter Property="Text" Value="Odrzucone" />
                                                        <Setter Property="TextColor" Value="DarkRed" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </VerticalStackLayout>

                                        <Button Grid.Column="1" Text="Anuluj" BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" TextColor="White" Clicked="OnCancelInvitationClicked" CommandParameter="{Binding .}" HeightRequest="35" CornerRadius="6">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding Status}" Value="Rejected">
                                                    <Setter Property="Text" Value="Usuń" />
                                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" />
                                                    <Setter Property="TextColor" Value="White" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </Grid>

                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" Margin="0,5"/>

            <VerticalStackLayout Spacing="10">
                <Label Text="Twoi Opiekunowie" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDarkText}}"/>
                <CollectionView ItemsSource="{Binding CareGivers}">                    <CollectionView.EmptyView>
                        <Label Text="Nie masz jeszcze opiekunów." FontSize="14" TextColor="Gray" HorizontalOptions="Center" Margin="0,20,0,0"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:User">
                            <Frame CornerRadius="10" Padding="15" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                    <Image Grid.Column="0" Source="dotnet_bot.png" HeightRequest="40" WidthRequest="40"/>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                        <Label Text="{Binding Email}" FontSize="12" TextColor="Gray" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="2" Text="Usuń" BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerDark}}" TextColor="White" Clicked="OnRemoveCareGiverClicked" CommandParameter="{Binding .}" HeightRequest="35" CornerRadius="6" VerticalOptions="Center"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>