<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.CalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="Historia Raportów"
    x:DataType="vm:CalendarViewModel">

    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <VerticalStackLayout IsVisible="{Binding IsCareGiver}" Spacing="10">
                    <Label FontAttributes="Bold" Text="Wybierz podopiecznego:" />
                    <Border
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                          Dark={StaticResource SurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                 Dark={StaticResource Gray600}}"
                        StrokeShape="RoundRectangle 8">
                        <Grid HeightRequest="50">
                            <Label
                                Margin="15,0,0,0"
                                FontSize="15"
                                HorizontalOptions="Start"
                                Text="{Binding SelectedCareTakerName}"
                                TextColor="{AppThemeBinding Light=Black,
                                                            Dark=White}"
                                VerticalOptions="Center" />
                            <Button
                                BackgroundColor="Transparent"
                                Command="{Binding SelectCareTakerCommand}"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding HasCareTakerSelected}" Spacing="15">

                    <Grid
                        Margin="0,0,0,10"
                        ColumnDefinitions="Auto, *, Auto"
                        VerticalOptions="Center">
                        <Button
                            Grid.Column="0"
                            Padding="0"
                            BackgroundColor="{StaticResource Primary}"
                            Command="{Binding ChangeMonthCommand}"
                            CommandParameter="Prev"
                            Text="&lt;"
                            WidthRequest="40" />
                        <Label
                            Grid.Column="1"
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Center"
                            Text="{Binding CurrentMonthName}"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="2"
                            Padding="0"
                            BackgroundColor="{StaticResource Primary}"
                            Command="{Binding ChangeMonthCommand}"
                            CommandParameter="Next"
                            Text="&gt;"
                            WidthRequest="40" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Days}" Spacing="10">
                        <BindableLayout.EmptyView>
                            <Label
                                Margin="0,20,0,0"
                                HorizontalOptions="Center"
                                Text="Brak raportów w tym miesiącu."
                                TextColor="{StaticResource Gray500}" />
                        </BindableLayout.EmptyView>

                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:CalendarDayItem">
                                <Border
                                    Padding="15"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                                      Dark={StaticResource SurfaceDark}}"
                                    IsVisible="{Binding HasData}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                             Dark={StaticResource Gray600}}"
                                    StrokeShape="RoundRectangle 8">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="OnDayTapped" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="*, Auto">
                                        <VerticalStackLayout
                                            Grid.Column="0"
                                            Spacing="2"
                                            VerticalOptions="Center">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="16"
                                                Text="{Binding Date, StringFormat='{0:dd MMMM yyyy}'}" />
                                            <Label
                                                FontAttributes="Bold"
                                                Text="{Binding Response.EvaluationStatus}"
                                                TextColor="{Binding StatusColor}" />
                                        </VerticalStackLayout>

                                        <Button
                                            Grid.Column="1"
                                            Clicked="OnDayDetailsClicked"
                                            CommandParameter="{Binding .}"
                                            HeightRequest="35"
                                            Text="Szczegóły" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator
            HorizontalOptions="Center"
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            VerticalOptions="Center"
            ZIndex="10" />

        <BoxView
            IsVisible="{Binding IsDayDetailsVisible}"
            Opacity="0.5"
            Color="Black">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseDetailsCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Border
            Margin="0"
            Padding="0"
            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                              Dark={StaticResource SurfaceDark}}"
            HorizontalOptions="Fill"
            IsVisible="{Binding IsDayDetailsVisible}"
            Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                     Dark={StaticResource Gray600}}"
            StrokeShape="RoundRectangle 20,20,0,0"
            VerticalOptions="End">

            <Grid Padding="0,0,0,20" RowDefinitions="Auto, Auto">

                <Grid
                    Grid.Row="0"
                    Padding="20"
                    ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding SelectedDay.Date, StringFormat='{0:dd MMMM yyyy}'}" />
                        <Label
                            FontSize="14"
                            Text="{Binding SelectedDay.Response.EvaluationStatus, StringFormat='Status: {0}'}"
                            TextColor="{StaticResource Primary}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            IsVisible="{Binding IsCareGiver}"
                            Text="{Binding SelectedDay.Response.TotalScore, StringFormat='Suma punktów: {0}'}" />
                    </VerticalStackLayout>
                    <Button
                        Grid.Column="1"
                        Padding="10,0"
                        BackgroundColor="{StaticResource Gray500}"
                        Command="{Binding CloseDetailsCommand}"
                        HeightRequest="35"
                        Text="Zamknij"
                        VerticalOptions="Start" />
                </Grid>

                <ScrollView
                    Grid.Row="1"
                    HeightRequest="350"
                    IsVisible="{Binding IsCareGiver}">
                    <VerticalStackLayout
                        Padding="20,0,20,20"
                        BindableLayout.ItemsSource="{Binding SelectedDayAnswers}"
                        Spacing="15">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:GivenAnswer">
                                <Border
                                    Padding="15"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                                      Dark={StaticResource SurfaceDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                             Dark={StaticResource Gray600}}"
                                    StrokeShape="RoundRectangle 8">
                                    <VerticalStackLayout Spacing="5">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="14"
                                            Text="{Binding QuestionText}" />
                                        <Label
                                            FontAttributes="Bold"
                                            Text="{Binding SelectedOptionText}"
                                            TextColor="{StaticResource Primary}" />
                                        <Label
                                            FontAttributes="Italic"
                                            Text="{Binding OpenTextResponse}"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                                        Dark={StaticResource Gray400}}" />
                                        <Label
                                            Margin="0,5,0,0"
                                            FontSize="12"
                                            Text="{Binding PointsAwarded, StringFormat='Punkty: {0}'}"
                                            TextColor="{StaticResource Gray500}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>