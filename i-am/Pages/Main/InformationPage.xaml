<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="i_am.Pages.Main.InformationPage"
             Title="Informacje alarmowe">

    <Shell.TitleView>
        <Grid HorizontalOptions="Fill" VerticalOptions="Center">
            <Label Text="Informacje alarmowe" 
                   TextColor="White" 
                   FontSize="30" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Start" 
                   VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="30" HorizontalOptions="Fill">

            <VerticalStackLayout Spacing="15">
                <Label Text="Szybki kontakt" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />

                <Border Padding="15" 
                        StrokeShape="RoundRectangle 12" 
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPhoneNumberTapped" CommandParameter="999" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Pogotowie ratunkowe" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="999" FontSize="24" FontAttributes="Bold" 
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Padding="15" 
                        StrokeShape="RoundRectangle 12" 
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPhoneNumberTapped" CommandParameter="112" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Numer alarmowy" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="112" FontSize="24" FontAttributes="Bold" 
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Padding="15" 
                        StrokeShape="RoundRectangle 12" 
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPhoneNumberTapped" CommandParameter="800012005" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Telefon Pogadania" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="800 012 005" FontSize="20" FontAttributes="Bold" 
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Padding="15" 
                        StrokeShape="RoundRectangle 12" 
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Wsparcie dla Dorosłych" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="800 702 222" FontSize="20" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPhoneNumberTapped" CommandParameter="800702222" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <HorizontalStackLayout HorizontalOptions="End" Spacing="5">
                            <Label Text="Czat:" FontSize="14" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                            <Label Text="centrumwsparcia.pl" FontSize="14" FontAttributes="Bold" TextDecorations="Underline" 
                                   TextColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDarkText}}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnWebsiteTapped" CommandParameter="https://centrumwsparcia.pl" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Padding="15" 
                        StrokeShape="RoundRectangle 12" 
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Telefon Zaufania Dzieci" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="116 111" FontSize="20" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPhoneNumberTapped" CommandParameter="116111" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <HorizontalStackLayout HorizontalOptions="End" Spacing="5">
                            <Label Text="Czat:" FontSize="14" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                            <Label Text="116111.pl/czatuj" FontSize="14" FontAttributes="Bold" TextDecorations="Underline" 
                                   TextColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDarkText}}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnWebsiteTapped" CommandParameter="https://116111.pl/czatuj" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Padding="15" 
                        StrokeShape="RoundRectangle 12" 
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Telefon Zaufania Dorosłych" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="116 123" FontSize="20" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPhoneNumberTapped" CommandParameter="116123" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <HorizontalStackLayout HorizontalOptions="End" Spacing="5">
                            <Label Text="Strona:" FontSize="14" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                            <Label Text="116sos.pl" FontSize="14" FontAttributes="Bold" TextDecorations="Underline" 
                                   TextColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDarkText}}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnWebsiteTapped" CommandParameter="https://116sos.pl" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15" Margin="0,10,0,30">
                <Label Text="O depresji" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />

                <Border Padding="20"
                        StrokeShape="RoundRectangle 12" 
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="• Depresja to choroba, a nie chwilowy smutek ani oznaka słabości. Może trwać tygodniami lub miesiącami i nie mija sama z siebie. Wpływa na sposób myślenia, odczuwania emocji oraz na codzienne funkcjonowanie." 
                               FontSize="15" LineHeight="1.3" HorizontalTextAlignment="Start"/>

                        <Label Text="• Objawy depresji mogą być różne u każdej osoby. Często pojawia się długotrwały smutek, brak energii lub zainteresowania rzeczami, które wcześniej sprawiały radość. Mogą też występować problemy ze snem, koncentracją lub apetytem." 
                               FontSize="15" LineHeight="1.3" HorizontalTextAlignment="Start"/>

                        <Label Text="• Depresja utrudnia codzienne życie i wykonywanie nawet prostych czynności. Osoba chora może mieć trudność z wstawaniem z łóżka, pracą lub kontaktami z innymi ludźmi. Z czasem może to prowadzić do poczucia bezradności i izolacji." 
                               FontSize="15" LineHeight="1.3" HorizontalTextAlignment="Start"/>

                        <Label Text="• Wsparcie i szybka reakcja otoczenia są bardzo ważne w leczeniu depresji. Regularne monitorowanie samopoczucia pomaga zauważyć pogorszenie stanu psychicznego. Dzięki temu osoba bliska może szybciej zareagować i zapewnić potrzebną pomoc." 
                               FontSize="15" LineHeight="1.3" HorizontalTextAlignment="Start"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>