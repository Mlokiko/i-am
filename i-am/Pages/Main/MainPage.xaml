<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    x:DataType="vm:MainPageViewModel">

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="30"
            HorizontalOptions="Center"
            Text="I AM"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <Grid Padding="20">
        <VerticalStackLayout
            HorizontalOptions="Fill"
            Spacing="25"
            VerticalOptions="Center">

            <ScrollView>
                <VerticalStackLayout Spacing="10">
                    <Button Command="{Binding GoToNotificationsCommand}" Text="Powiadomienia" />

                    <Button
                        Command="{Binding GoToDailyActivityCommand}"
                        IsVisible="{Binding IsCareTaker}"
                        Text="Codzienna Aktywność" />

                    <Button Command="{Binding GoToCalendarCommand}" Text="Kalendarz" />

                    <Button
                        Command="{Binding GoToManageCareTakersCommand}"
                        IsVisible="{Binding IsCaregiver}"
                        Text="Zarządzaj Podopiecznymi" />

                    <Button
                        Command="{Binding GoToManageCareGiversCommand}"
                        IsVisible="{Binding IsCareTaker}"
                        Text="Zarządzaj Opiekunami" />

                    <Button Command="{Binding GoToSettingsCommand}" Text="Ustawienia" />

                </VerticalStackLayout>
            </ScrollView>

            <VerticalStackLayout>

                <Label
                    Padding="20"
                    HorizontalOptions="Center"
                    Style="{StaticResource SubtitleLabelStyle}"
                    Text="Informacje alarmowe">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToInformationCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>