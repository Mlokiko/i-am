<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:i_am.ViewModels"
             x:Class="i_am.Pages.Main.MainPage"
             x:DataType="viewModels:MainPageViewModel"
             Shell.NavBarIsVisible="True"
             Title="I AM">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="10,0">
            <Label Text="I AM"
                   Grid.Column="0"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   HorizontalOptions="Start"/>

            <!-- Przycisk ALERT - widoczny tylko dla podopiecznych -->
            <Button Grid.Column="1"
                    Text="ALERT"
                    Style="{StaticResource AlertButtonStyle}"
                    Command="{Binding SendEmergencyAlertCommand}"
                    IsVisible="{Binding IsCareTaker}"/>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <Grid Padding="30">
            <VerticalStackLayout
                HorizontalOptions="Fill"
                Spacing="15"
                VerticalOptions="Center">
                <Button Command="{Binding GoToNotificationsCommand}" Text="Powiadomienia" />
                <Button
                    Command="{Binding GoToDailyActivityCommand}"
                    IsVisible="{Binding IsCareTaker}"
                    Text="Codzienna Aktywność" />
                <Button Command="{Binding GoToCalendarCommand}" Text="Kalendarz" />
                <Button
                    Command="{Binding GoToManageCareTakersCommand}"
                    IsVisible="{Binding IsCaregiver}"
                    Text="Zarządzaj Podopiecznymi" />
                <Button
                    Command="{Binding GoToManageCareGiversCommand}"
                    IsVisible="{Binding IsCareTaker}"
                    Text="Zarządzaj Opiekunami" />
                <Button Command="{Binding GoToSettingsCommand}" Text="Ustawienia" />
                <Label
                    Padding="20"
                    HorizontalOptions="Center"
                    Style="{StaticResource SubtitleLabelStyle}"
                    Text="Informacje alarmowe">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToInformationCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>