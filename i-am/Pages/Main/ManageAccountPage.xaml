<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.ManageAccountPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="Zarządzanie kontem"
    x:DataType="vm:ManageAccountViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="{Binding Name}" />

            <BoxView
                Margin="0,10"
                HeightRequest="1"
                Color="{AppThemeBinding Light={StaticResource Gray200},
                                        Dark={StaticResource Gray500}}" />

            <Grid
                ColumnDefinitions="Auto, *"
                ColumnSpacing="20"
                RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto"
                RowSpacing="25">

                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    FontAttributes="Bold"
                    Text="Email:"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                Dark={StaticResource Gray400}}"
                    VerticalOptions="Center" />
                <Label
                    Grid.Row="0"
                    Grid.Column="1"
                    Text="{Binding Email}"
                    VerticalOptions="Center" />

                <Label
                    Grid.Row="1"
                    Grid.Column="0"
                    FontAttributes="Bold"
                    Text="Nr telefonu:"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                Dark={StaticResource Gray400}}"
                    VerticalOptions="Center" />
                <Label
                    Grid.Row="1"
                    Grid.Column="1"
                    IsVisible="{Binding IsNotEditing}"
                    Text="{Binding PhoneNumber}"
                    VerticalOptions="Center" />
                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Padding="10,0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                      Dark={StaticResource SurfaceDark}}"
                    IsVisible="{Binding IsEditing}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                             Dark={StaticResource Gray500}}"
                    StrokeShape="RoundRectangle 8">
                    <Entry
                        Keyboard="Telephone"
                        Placeholder="Twój numer telefonu"
                        Text="{Binding EditPhoneNumber}"
                        VerticalOptions="Center" />
                </Border>

                <Label
                    Grid.Row="2"
                    Grid.Column="0"
                    FontAttributes="Bold"
                    Text="Urodziny:"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                Dark={StaticResource Gray400}}"
                    VerticalOptions="Center" />
                <Label
                    Grid.Row="2"
                    Grid.Column="1"
                    Text="{Binding BirthDate}"
                    VerticalOptions="Center" />

                <Label
                    Grid.Row="3"
                    Grid.Column="0"
                    FontAttributes="Bold"
                    Text="Płeć:"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                Dark={StaticResource Gray400}}"
                    VerticalOptions="Center" />
                <Label
                    Grid.Row="3"
                    Grid.Column="1"
                    IsVisible="{Binding IsNotEditing}"
                    Text="{Binding Sex}"
                    VerticalOptions="Center" />
                <Border
                    Grid.Row="3"
                    Grid.Column="1"
                    Padding="10,0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                      Dark={StaticResource SurfaceDark}}"
                    IsVisible="{Binding IsEditing}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                             Dark={StaticResource Gray500}}"
                    StrokeShape="RoundRectangle 8">
                    <Picker
                        ItemsSource="{Binding SexOptions}"
                        SelectedItem="{Binding EditSex}"
                        VerticalOptions="Center" />
                </Border>

                <Label
                    Grid.Row="4"
                    Grid.Column="0"
                    FontAttributes="Bold"
                    Text="Rola:"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                Dark={StaticResource Gray400}}"
                    VerticalOptions="Center" />
                <Label
                    Grid.Row="4"
                    Grid.Column="1"
                    Text="{Binding Role}"
                    VerticalOptions="Center" />

                <Label
                    Grid.Row="5"
                    Grid.Column="0"
                    FontAttributes="Bold"
                    Text="Dołączono:"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                Dark={StaticResource Gray400}}"
                    VerticalOptions="Center" />
                <Label
                    Grid.Row="5"
                    Grid.Column="1"
                    Text="{Binding CreatedAt}"
                    VerticalOptions="Center" />
            </Grid>

            <VerticalStackLayout Margin="0,20,0,30" Spacing="15">

                <Button
                    Command="{Binding EnableEditModeCommand}"
                    IsVisible="{Binding IsNotEditing}"
                    Text="Edytuj dane" />

                <Grid
                    ColumnDefinitions="*, *"
                    ColumnSpacing="15"
                    IsVisible="{Binding IsEditing}">
                    <Button
                        Grid.Column="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                          Dark={StaticResource Gray600}}"
                        Command="{Binding CancelEditCommand}"
                        Text="Anuluj" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="{StaticResource Success}"
                        Command="{Binding SaveChangesCommand}"
                        Text="Zapisz" />
                </Grid>

                <BoxView
                    Margin="0,15"
                    HeightRequest="1"
                    Color="{AppThemeBinding Light={StaticResource Gray200},
                                            Dark={StaticResource Gray500}}" />

                <Button
                    BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight},
                                                      Dark={StaticResource DangerDark}}"
                    Command="{Binding DeleteAccountCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    Text="Usuń konto"
                    TextColor="White" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>