<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.ManageConnectionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    x:Name="RootPage"
    Title="{Binding PageTitle}"
    x:DataType="vm:ManageConnectionsViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Border
                Padding="15"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                  Dark={StaticResource SurfaceDark}}"
                Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                         Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="{Binding InviteLabelText}"
                        TextColor="{AppThemeBinding Light={StaticResource Primary},
                                                    Dark={StaticResource PrimaryDarkText}}" />
                    <Entry
                        ClearButtonVisibility="WhileEditing"
                        Keyboard="Email"
                        Placeholder="{Binding InvitePlaceholder}"
                        Text="{Binding InviteEmail}" />
                    <Button Command="{Binding InviteCommand}" Text="Wyślij Zaproszenie" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10">
                <Label
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="Aktywne zaproszenia" />
                <CollectionView ItemsSource="{Binding AllInvitations}">
                    <CollectionView.EmptyView>
                        <Label
                            Padding="20"
                            HorizontalOptions="Center"
                            Text="Brak aktywnych zaproszeń."
                            TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                        Dark={StaticResource Gray400}}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Invitation">
                            <Border
                                Margin="0,0,0,10"
                                Padding="12"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                                  Dark={StaticResource SurfaceDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                         Dark={StaticResource Gray600}}"
                                StrokeShape="RoundRectangle 8">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label FontAttributes="Bold" FontSize="14">
                                            <Label.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding IsSentByMe}"
                                                    TargetType="Label"
                                                    Value="True">
                                                    <Setter Property="Text" Value="{Binding ReceiverEmail, StringFormat='Do: {0}'}" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding IsSentByMe}"
                                                    TargetType="Label"
                                                    Value="False">
                                                    <Setter Property="Text" Value="{Binding SenderName, StringFormat='Od: {0}'}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label FontSize="12">
                                            <Label.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding Status}"
                                                    TargetType="Label"
                                                    Value="Pending">
                                                    <Setter Property="Text" Value="Oczekujące..." />
                                                    <Setter Property="TextColor" Value="{StaticResource Warning}" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding Status}"
                                                    TargetType="Label"
                                                    Value="Rejected">
                                                    <Setter Property="Text" Value="Odrzucone" />
                                                    <Setter Property="TextColor" Value="{StaticResource Danger}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>

                                    <Button
                                        Grid.Column="1"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight},
                                                                          Dark={StaticResource DangerDark}}"
                                        Command="{Binding BindingContext.CancelInvitationCommand, Source={x:Reference RootPage}}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="6"
                                        HeightRequest="35"
                                        IsVisible="{Binding IsSentByMe}"
                                        Text="Usuń"
                                        TextColor="White"
                                        VerticalOptions="Center" />

                                    <HorizontalStackLayout Grid.Column="1" Spacing="10">
                                        <HorizontalStackLayout.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsSentByMe}"
                                                TargetType="HorizontalStackLayout"
                                                Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </HorizontalStackLayout.Triggers>

                                        <Button
                                            BackgroundColor="{StaticResource Success}"
                                            Command="{Binding BindingContext.AcceptCommand, Source={x:Reference RootPage}}"
                                            CommandParameter="{Binding .}"
                                            CornerRadius="6"
                                            HeightRequest="35"
                                            Text="Akceptuj"
                                            TextColor="White" />
                                        <Button
                                            BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight},
                                                                              Dark={StaticResource DangerDark}}"
                                            Command="{Binding BindingContext.RejectCommand, Source={x:Reference RootPage}}"
                                            CommandParameter="{Binding .}"
                                            CornerRadius="6"
                                            HeightRequest="35"
                                            Text="Odrzuć"
                                            TextColor="White" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="{Binding ListTitleText}" />
                <CollectionView ItemsSource="{Binding Connections}">
                    <CollectionView.EmptyView>
                        <Label
                            Padding="20"
                            HorizontalOptions="Center"
                            Text="{Binding EmptyListText}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                        Dark={StaticResource Gray400}}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:User">
                            <Border
                                Margin="0,0,0,10"
                                Padding="15"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                                  Dark={StaticResource SurfaceDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                         Dark={StaticResource Gray600}}"
                                StrokeShape="RoundRectangle 12">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            Text="{Binding Name}" />
                                        <Label
                                            FontSize="13"
                                            Text="{Binding Email}"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                                        Dark={StaticResource Gray400}}" />
                                    </VerticalStackLayout>
                                    <Button
                                        Grid.Column="1"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight},
                                                                          Dark={StaticResource DangerDark}}"
                                        Command="{Binding BindingContext.RemoveConnectionCommand, Source={x:Reference RootPage}}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="6"
                                        HeightRequest="35"
                                        Text="Usuń"
                                        TextColor="White"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>