<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.ManageConnectionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="{Binding PageTitle}"
    x:DataType="vm:ManageConnectionsViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontSize="18"
                        Style="{StaticResource TitleLabelStyle}"
                        Text="{Binding InviteLabelText}" />

                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry
                            ClearButtonVisibility="WhileEditing"
                            Keyboard="Email"
                            Placeholder="{Binding InvitePlaceholder}"
                            Text="{Binding InviteEmail}" />
                    </Border>

                    <Button Command="{Binding InviteCommand}" Text="Wyślij Zaproszenie" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource TitleLabelStyle}" Text="Aktywne zaproszenia" />

                <CollectionView ItemsSource="{Binding AllInvitations}">
                    <CollectionView.EmptyView>
                        <Label
                            Padding="20"
                            HorizontalOptions="Center"
                            Style="{StaticResource SubtitleLabelStyle}"
                            Text="Brak aktywnych zaproszeń." />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Invitation">
                            <Border
                                Margin="0,0,0,10"
                                Padding="12"
                                Style="{StaticResource CardBorderStyle}">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label FontAttributes="Bold" FontSize="14">
                                            <Label.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding IsSentByMe}"
                                                    TargetType="Label"
                                                    Value="True">
                                                    <Setter Property="Text" Value="{Binding ReceiverEmail, StringFormat='Do: {0}'}" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding IsSentByMe}"
                                                    TargetType="Label"
                                                    Value="False">
                                                    <Setter Property="Text" Value="{Binding SenderName, StringFormat='Od: {0}'}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label FontSize="12">
                                            <Label.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding Status}"
                                                    TargetType="Label"
                                                    Value="Pending">
                                                    <Setter Property="Text" Value="Oczekujące..." />
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarningLight}, Dark={StaticResource WarningDark}}" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding Status}"
                                                    TargetType="Label"
                                                    Value="Rejected">
                                                    <Setter Property="Text" Value="Odrzucone" />
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarningLight}, Dark={StaticResource WarningDark}}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>

                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManageConnectionsViewModel}}, Path=CancelInvitationCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="6"
                                        HeightRequest="35"
                                        IsVisible="{Binding IsSentByMe}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Text="Usuń"
                                        VerticalOptions="Center" />

                                    <HorizontalStackLayout Grid.Column="1" Spacing="10">
                                        <HorizontalStackLayout.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsSentByMe}"
                                                TargetType="HorizontalStackLayout"
                                                Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </HorizontalStackLayout.Triggers>

                                        <Button
                                            BackgroundColor="{AppThemeBinding Light={StaticResource SuccessLight},
                                                                              Dark={StaticResource SuccessDark}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManageConnectionsViewModel}}, Path=AcceptCommand}"
                                            CommandParameter="{Binding .}"
                                            CornerRadius="6"
                                            HeightRequest="35"
                                            Text="Akceptuj"
                                            TextColor="White" />

                                        <Button
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManageConnectionsViewModel}}, Path=RejectCommand}"
                                            CommandParameter="{Binding .}"
                                            CornerRadius="6"
                                            HeightRequest="35"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Text="Odrzuć"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding ListTitleText}" />

                <CollectionView ItemsSource="{Binding Connections}">
                    <CollectionView.EmptyView>
                        <Label
                            Padding="20"
                            HorizontalOptions="Center"
                            Style="{StaticResource SubtitleLabelStyle}"
                            Text="{Binding EmptyListText}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:User">
                            <Border Margin="0,0,0,10" Style="{StaticResource CardBorderStyle}">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding Name}" />
                                        <Label Style="{StaticResource SubtitleLabelStyle}" Text="{Binding Email}" />
                                    </VerticalStackLayout>

                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManageConnectionsViewModel}}, Path=RemoveConnectionCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="6"
                                        HeightRequest="35"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Text="Usuń"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>