<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:i_am.Models"
             x:Class="i_am.Pages.Main.NotificationsPage"
             Title="Powiadomienia">
    <Grid Padding="20">

        <CollectionView x:Name="NotificationsList" ItemsSource="{Binding Invitations}">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="📭" FontSize="50" HorizontalOptions="Center"/>
                    <Label Text="Brak nowych powiadomień" FontSize="18" TextColor="Gray" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Invitation">
                    <Frame CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderColor="LightGray" HasShadow="True">
                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto, Auto" RowSpacing="10" ColumnSpacing="10">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                                <Label Text="{Binding SenderName}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="Wysłał(a) Ci zaproszenie do połączenia kont." FontSize="14" TextColor="Gray" />
                                <Label Text="{Binding Status}" FontSize="12" TextColor="#2B0B98" FontAttributes="Italic" Margin="0,5,0,0"/>
                            </VerticalStackLayout>

                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" HorizontalOptions="End" Spacing="10">
                                <HorizontalStackLayout.Triggers>
                                    <DataTrigger TargetType="HorizontalStackLayout" Binding="{Binding Status}" Value="Rejected">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="HorizontalStackLayout" Binding="{Binding Status}" Value="Deleted">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </HorizontalStackLayout.Triggers>

                                <Button Text="Odrzuć" 
                                        BackgroundColor="#FFF0F0" 
                                        TextColor="DarkRed"
                                        Clicked="OnRejectClicked"
                                        CommandParameter="{Binding .}" 
                                        HeightRequest="40" 
                                        CornerRadius="8"/>

                                <Button Text="Akceptuj" 
                                        BackgroundColor="#28A745" 
                                        TextColor="White"
                                        Clicked="OnAcceptClicked"
                                        CommandParameter="{Binding .}" 
                                        HeightRequest="40" 
                                        CornerRadius="8"
                                        FontAttributes="Bold"/>
                            </HorizontalStackLayout>

                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                                   Text="Odrzuciłeś to zaproszenie." 
                                   TextColor="DarkRed" 
                                   FontAttributes="Bold" 
                                   VerticalOptions="Center" 
                                   IsVisible="False">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Rejected">
                                        <Setter Property="IsVisible" Value="True" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" IsVisible="False" Spacing="10">
                                <VerticalStackLayout.Triggers>
                                    <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding Status}" Value="Deleted">
                                        <Setter Property="IsVisible" Value="True" />
                                    </DataTrigger>
                                </VerticalStackLayout.Triggers>

                                <Label Text="Użytkownik usunął to zaproszenie lub zakończył połączenie." 
                                       TextColor="Gray" 
                                       FontAttributes="Italic" />

                                <Button Text="Zrozumiałem (Usuń powiadomienie)" 
                                        BackgroundColor="#6C757D" 
                                        TextColor="White"
                                        Clicked="OnAcknowledgeDeletedClicked"
                                        CommandParameter="{Binding .}" 
                                        HeightRequest="40" 
                                        CornerRadius="8"
                                        HorizontalOptions="End"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
</ContentPage>