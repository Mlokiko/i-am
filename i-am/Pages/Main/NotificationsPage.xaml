<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:i_am.Models"
             x:Class="i_am.Pages.Main.NotificationsPage"
             Title="Powiadomienia">
    <Grid Padding="20">

        <CollectionView x:Name="NotificationsListView" ItemsSource="{Binding NotificationsList}">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="📭" FontSize="50" HorizontalOptions="Center"/>
                    <Label Text="Brak nowych powiadomień" FontSize="18" TextColor="Gray" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AppNotification">
                    <Frame CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderColor="LightGray" HasShadow="True">
                        <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="5">

                            <Label Grid.Row="0" Grid.Column="0" 
                                   Text="{Binding Title}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="#2B0B98"/>

                            <Label Grid.Row="0" Grid.Column="1" 
                                   Text="{Binding CreatedAt, StringFormat='{0:dd.MM.yyyy HH:mm}'}" 
                                   FontSize="12" 
                                   TextColor="Gray" 
                                   VerticalOptions="Center"/>

                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                   Text="{Binding Message}" 
                                   FontSize="14" 
                                   Margin="0,5,0,10"/>

                            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                    Text="Zrozumiałem (Usuń powiadomienie)" 
                                    BackgroundColor="#6C757D" 
                                    TextColor="White"
                                    Clicked="OnDeleteNotificationClicked"
                                    CommandParameter="{Binding .}" 
                                    HeightRequest="40" 
                                    CornerRadius="8"
                                    HorizontalOptions="End"/>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
</ContentPage>