<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.NotificationsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:i_am.Models"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="Powiadomienia"
    x:DataType="vm:NotificationsViewModel">

    <Grid RowDefinitions="*, Auto">

        <CollectionView Grid.Row="0" ItemsSource="{Binding NotificationsList}">
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    Margin="20,0,20,0"
                    HorizontalOptions="Center"
                    Spacing="10"
                    VerticalOptions="Center">
                    <Label
                        FontSize="50"
                        HorizontalOptions="Center"
                        Text="📭" />
                    <Label
                        FontSize="18"
                        HorizontalOptions="Center"
                        Style="{StaticResource SubtitleLabelStyle}"
                        Text="Brak nowych powiadomień" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AppNotification">
                    <Border Margin="20,15,20,0" Style="{StaticResource CardBorderStyle}">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <VerticalStackLayout
                                Grid.Row="0"
                                Grid.Column="0"
                                Spacing="5">
                                <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding Title}" />
                                <Label
                                    FontSize="14"
                                    Style="{StaticResource SubtitleLabelStyle}"
                                    Text="{Binding Message}" />
                                <Label
                                    FontSize="12"
                                    Text="{Binding CreatedAt, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray400},
                                                                Dark={StaticResource Gray500}}" />
                            </VerticalStackLayout>

                            <Label
                                Grid.Row="0"
                                Grid.Column="1"
                                FontAttributes="Bold"
                                FontSize="20"
                                HorizontalOptions="End"
                                Style="{StaticResource SubtitleLabelStyle}"
                                Text="✕"
                                VerticalOptions="Start">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=DismissNotificationCommand}" CommandParameter="{Binding .}" />
                                </Label.GestureRecognizers>
                            </Label>

                            <Button
                                Grid.Row="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Margin="0,15,0,0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Gray500},
                                                                  Dark={StaticResource Gray600}}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=NotificationActionCommand}"
                                CommandParameter="{Binding .}"
                                CornerRadius="8"
                                HeightRequest="40"
                                HorizontalOptions="End"
                                Text="Ok">
                                <Button.Triggers>
                                    <DataTrigger
                                        Binding="{Binding Type}"
                                        TargetType="Button"
                                        Value="NewInvitation">
                                        <Setter Property="Text" Value="Przejdź do zaproszeń" />
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding Type}"
                                        TargetType="Button"
                                        Value="DailyReportAlert">
                                        <Setter Property="Text" Value="Przejdź do wpisu" />
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Grid.Row="1"
            Margin="20,10,20,10"
            Command="{Binding ClearAllNotificationsCommand}"
            CornerRadius="8"
            Text="Wyczyść wszystkie powiadomienia">
            <Button.Triggers>
                <DataTrigger
                    Binding="{Binding NotificationsList.Count}"
                    TargetType="Button"
                    Value="0">
                    <Setter Property="IsVisible" Value="False" />
                </DataTrigger>
            </Button.Triggers>
        </Button>
    </Grid>
</ContentPage>