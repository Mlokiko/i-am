<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.PermissionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    xmlns:local="clr-namespace:i_am.Resources.Strings"
    x:DataType="vm:PermissionsViewModel"
    Shell.NavBarIsVisible="False">

    <Grid Padding="20">
        <VerticalStackLayout Spacing="25" VerticalOptions="Center">

            <Image
                Margin="0,0,0,20"
                HeightRequest="150"
                HorizontalOptions="Center"
                Source="{AppThemeBinding Light=i_am_logo_black.svg,
                                         Dark=i_am_logo_white.svg}" />

            <Label
                HorizontalTextAlignment="Center"
                Style="{StaticResource SubtitleLabelStyle}"
                Text="{Binding Source={x:Static local:AppStrings.Permissions_Description}}" />

            <Border
                Stroke="{Binding NotificationStatusColor}"
                StrokeThickness="2"
                Style="{StaticResource CardBorderStyle}">
                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                    <VerticalStackLayout
                        Grid.Row="0"
                        Grid.Column="0"
                        Spacing="5">
                        <Label
                            FontSize="18"
                            Style="{StaticResource TitleLabelStyle}"
                            Text="{Binding Source={x:Static local:AppStrings.Permissions_Notifications}}" />
                        <Label Style="{StaticResource SubtitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Permissions_NotificationsDesc}}" />
                    </VerticalStackLayout>

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        Command="{Binding RequestNotificationsCommand}"
                        Text="{Binding Source={x:Static local:AppStrings.Permissions_Allow}}"
                        VerticalOptions="Center">
                        <Button.Triggers>
                            <DataTrigger
                                Binding="{Binding IsNotificationGranted}"
                                TargetType="Button"
                                Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Label
                        Grid.Row="0"
                        Grid.Column="1"
                        FontAttributes="Bold"
                        IsVisible="{Binding IsNotificationGranted}"
                        Text="{Binding Source={x:Static local:AppStrings.Permissions_Granted}}"
                        TextColor="Green"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border
                Stroke="{Binding CameraStatusColor}"
                StrokeThickness="2"
                Style="{StaticResource CardBorderStyle}">
                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                    <VerticalStackLayout
                        Grid.Row="0"
                        Grid.Column="0"
                        Spacing="5">
                        <Label
                            FontSize="18"
                            Style="{StaticResource TitleLabelStyle}"
                            Text="Aparat" />
                        <Label Style="{StaticResource SubtitleLabelStyle}" Text="Służy do robienia zdjęć twarzy oraz otoczenia na potrzeby dziennego raportu." />
                    </VerticalStackLayout>

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        Command="{Binding RequestCameraCommand}"
                        Text="{Binding Source={x:Static local:AppStrings.Permissions_Allow}}"
                        VerticalOptions="Center">
                        <Button.Triggers>
                            <DataTrigger
                                Binding="{Binding IsCameraGranted}"
                                TargetType="Button"
                                Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Label
                        Grid.Row="0"
                        Grid.Column="1"
                        FontAttributes="Bold"
                        IsVisible="{Binding IsCameraGranted}"
                        Text="{Binding Source={x:Static local:AppStrings.Permissions_Granted}}"
                        TextColor="Green"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border
                Stroke="{Binding StorageStatusColor}"
                StrokeThickness="2"
                Style="{StaticResource CardBorderStyle}">
                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                    <VerticalStackLayout
                        Grid.Row="0"
                        Grid.Column="0"
                        Spacing="5">
                        <Label
                            FontSize="18"
                            Style="{StaticResource TitleLabelStyle}"
                            Text="Pliki i multimedia" />
                        <Label Style="{StaticResource SubtitleLabelStyle}" Text="Służy do zapisywania zrobionych zdjęć oraz ich bezpiecznego wczytywania." />
                    </VerticalStackLayout>

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        Command="{Binding RequestStorageCommand}"
                        Text="{Binding Source={x:Static local:AppStrings.Permissions_Allow}}"
                        VerticalOptions="Center">
                        <Button.Triggers>
                            <DataTrigger
                                Binding="{Binding IsStorageGranted}"
                                TargetType="Button"
                                Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Label
                        Grid.Row="0"
                        Grid.Column="1"
                        FontAttributes="Bold"
                        IsVisible="{Binding IsStorageGranted}"
                        Text="{Binding Source={x:Static local:AppStrings.Permissions_Granted}}"
                        TextColor="Green"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <Label
                HorizontalTextAlignment="Center"
                Style="{StaticResource SubtitleLabelStyle}"
                Text="Uprawnienia można potem zmienić w Ustawieniach." />

            <Button
                Margin="0,40,0,0"
                Command="{Binding FinishOnboardingCommand}"
                FontAttributes="Bold"
                HeightRequest="50"
                Text="{Binding Source={x:Static local:AppStrings.Permissions_Continue}}" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>