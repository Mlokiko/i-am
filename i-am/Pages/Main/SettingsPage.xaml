<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="Ustawienia"
    x:DataType="vm:SettingsViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="Wygląd" />

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Motyw aplikacji" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="Wybierz preferowany wygląd" />
                        </VerticalStackLayout>

                        <Picker
                            Grid.Column="1"
                            HorizontalOptions="End"
                            ItemsSource="{Binding ThemeOptions}"
                            SelectedItem="{Binding SelectedTheme}"
                            WidthRequest="150" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsCareTaker}" Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="Czas i Raporty" />

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Początek doby" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="Godzina, od której liczony jest nowy dzień" />
                        </VerticalStackLayout>
                        <Picker
                            Grid.Column="1"
                            ItemsSource="{Binding HoursList}"
                            SelectedItem="{Binding SelectedDayStartHour}"
                            WidthRequest="100" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Ogranicz czas odpowiedzi" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="Włącz, aby móc wysyłać raport tylko w wybranych godzinach" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding IsActivityTimeRestricted}" />
                    </Grid>
                </Border>

                <Border IsVisible="{Binding IsActivityTimeRestricted}" Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Style="{StaticResource TitleLabelStyle}" Text="Okno czasowe" />
                        <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="10">
                            <Picker
                                Title="Od"
                                Grid.Column="0"
                                ItemsSource="{Binding HoursList}"
                                SelectedItem="{Binding SelectedRestrictionStartHour}" />
                            <Label
                                Grid.Column="1"
                                Text="do"
                                VerticalOptions="Center" />
                            <Picker
                                Title="Do"
                                Grid.Column="2"
                                ItemsSource="{Binding HoursList}"
                                SelectedItem="{Binding SelectedRestrictionEndHour}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="Powiadomienia" />

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Powiadomienia Push" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="Otrzymuj alerty i przypomnienia" />
                        </VerticalStackLayout>

                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding AreNotificationsEnabled}"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="Uprawnienia systemowe" />

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Zarządzaj uprawnieniami" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="Otwórz ustawienia systemu, aby zmienić dostęp do powiadomień" />
                        </VerticalStackLayout>

                        <Button
                            Grid.Column="1"
                            Command="{Binding OpenSystemSettingsCommand}"
                            Text="Otwórz"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Button
                    Margin="0,10,0,20"
                    Command="{Binding SaveSettingsCommand}"
                    Text="Zapisz ustawienia" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>