<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    Title="Ustawienia"
    x:DataType="vm:SettingsViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="Wygląd" />
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid
                        ColumnDefinitions="*, Auto"
                        ColumnSpacing="10"
                        RowDefinitions="Auto, Auto"
                        VerticalOptions="Center">
                        <Label Style="{StaticResource TitleLabelStyle}" Text="Motyw aplikacji" />
                        <Label
                            Grid.Row="1"
                            Style="{StaticResource SubtitleLabelStyle}"
                            Text="Wybierz preferowany wygląd" />

                        <Picker
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            HorizontalOptions="End"
                            ItemsSource="{Binding ThemeOptions}"
                            SelectedItem="{Binding SelectedTheme}"
                            VerticalOptions="Center"
                            WidthRequest="150" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsCareTaker}" Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="Codzienna Aktywność" />
                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="15">
                        <Grid
                            ColumnDefinitions="*, Auto"
                            ColumnSpacing="10"
                            RowDefinitions="Auto, Auto">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Początek doby" />
                            <Label
                                Grid.Row="1"
                                Style="{StaticResource SubtitleLabelStyle}"
                                Text="Godzina, od której liczony jest nowy dzień" />
                            <Picker
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                ItemsSource="{Binding HoursList}"
                                SelectedItem="{Binding SelectedDayStartHour}"
                                VerticalOptions="Center"
                                WidthRequest="100" />
                        </Grid>

                        <BoxView Style="{StaticResource DividerStyle}" />

                        <Grid
                            ColumnDefinitions="*, Auto"
                            ColumnSpacing="10"
                            RowDefinitions="Auto, Auto">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Ogranicz czas odpowiedzi" />
                            <Label
                                Grid.Row="1"
                                Style="{StaticResource SubtitleLabelStyle}"
                                Text="Włącz, aby móc wysyłać wpis tylko w wybranych godzinach" />
                            <Switch
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                IsToggled="{Binding IsActivityTimeRestricted}"
                                VerticalOptions="Center" />
                        </Grid>

                        <Grid
                            ColumnDefinitions="*, Auto, *"
                            ColumnSpacing="10"
                            IsVisible="{Binding IsActivityTimeRestricted}">
                            <Picker
                                Title="Od"
                                ItemsSource="{Binding HoursList}"
                                SelectedItem="{Binding SelectedRestrictionStartHour}" />
                            <Label
                                Grid.Column="1"
                                Text="do"
                                VerticalOptions="Center" />
                            <Picker
                                Title="Do"
                                Grid.Column="2"
                                ItemsSource="{Binding HoursList}"
                                SelectedItem="{Binding SelectedRestrictionEndHour}" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="Powiadomienia" />
                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="15">

                        <Grid
                            ColumnDefinitions="*, Auto"
                            ColumnSpacing="10"
                            RowDefinitions="Auto, Auto">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Powiadomienia systemowe" />
                            <Label
                                Grid.Row="1"
                                Style="{StaticResource SubtitleLabelStyle}"
                                Text="Powiadomienia PUSH w systemie Android" />
                            <Switch
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                IsToggled="{Binding AreNotificationsEnabled}"
                                VerticalOptions="Center" />
                        </Grid>

                        <VerticalStackLayout IsVisible="{Binding IsCareTaker}" Spacing="15">
                            <BoxView Style="{StaticResource DividerStyle}" />

                            <Grid
                                ColumnDefinitions="*, Auto"
                                ColumnSpacing="10"
                                RowDefinitions="Auto, Auto">
                                <Label Style="{StaticResource TitleLabelStyle}" Text="Codzienne przypomnienie" />
                                <Label
                                    Grid.Row="1"
                                    Style="{StaticResource SubtitleLabelStyle}"
                                    Text="Przypominaj mi o wypełnieniu wpisu" />
                                <Switch
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    IsToggled="{Binding IsDailyReminderEnabled}"
                                    VerticalOptions="Center" />
                            </Grid>

                            <Grid
                                ColumnDefinitions="*, Auto"
                                ColumnSpacing="10"
                                IsVisible="{Binding IsDailyReminderEnabled}">
                                <Label
                                    Style="{StaticResource TitleLabelStyle}"
                                    Text="Godzina przypomnienia"
                                    VerticalOptions="Center" />
                                <HorizontalStackLayout
                                    Grid.Column="1"
                                    Spacing="5"
                                    VerticalOptions="Center">
                                    <Picker
                                        ItemsSource="{Binding HoursList}"
                                        SelectedItem="{Binding SelectedReminderHour}"
                                        WidthRequest="90" />
                                    <Label
                                        FontAttributes="Bold"
                                        Text=":"
                                        VerticalOptions="Center" />
                                    <Picker
                                        ItemsSource="{Binding MinutesList}"
                                        SelectedItem="{Binding SelectedReminderMinute}"
                                        WidthRequest="70" />
                                </HorizontalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView Style="{StaticResource DividerStyle}" />

                        <Grid
                            ColumnDefinitions="*, Auto"
                            ColumnSpacing="10"
                            RowDefinitions="Auto, Auto">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Powiadomienia o zaproszeniach" />
                            <Label
                                Grid.Row="1"
                                Style="{StaticResource SubtitleLabelStyle}"
                                Text="O nowych/odrzuconych zaproszeniach itp." />
                            <Picker
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                HorizontalOptions="End"
                                ItemsSource="{Binding SystemFilterOptions}"
                                SelectedItem="{Binding SelectedSystemFilter}"
                                VerticalOptions="Center"
                                WidthRequest="180" />
                        </Grid>

                        <BoxView IsVisible="{Binding IsCareGiver}" Style="{StaticResource DividerStyle}" />

                        <Grid
                            ColumnDefinitions="*, Auto"
                            ColumnSpacing="10"
                            IsVisible="{Binding IsCareGiver}"
                            RowDefinitions="Auto, Auto">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="Wyniki codzienne" />
                            <Label
                                Grid.Row="1"
                                Style="{StaticResource SubtitleLabelStyle}"
                                Text="Jakie wyniki ankiet chcesz otrzymywać?" />
                            <Picker
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                HorizontalOptions="End"
                                ItemsSource="{Binding SurveyFilterOptions}"
                                SelectedItem="{Binding SelectedSurveyFilter}"
                                VerticalOptions="Center"
                                WidthRequest="180" />
                        </Grid>

                        <BoxView IsVisible="{Binding IsCareGiver}" Style="{StaticResource DividerStyle}" />

                        <VerticalStackLayout IsVisible="{Binding IsCareGiver}">
                            <Grid
                                ColumnDefinitions="*, Auto"
                                ColumnSpacing="10"
                                IsVisible="{Binding IsCareGiver}"
                                RowDefinitions="Auto, Auto">
                                <Label Style="{StaticResource TitleLabelStyle}" Text="Brak aktywności podopiecznego" />
                                <Label
                                    Grid.Row="1"
                                    Style="{StaticResource SubtitleLabelStyle}"
                                    Text="Ostrzegaj, gdy podopieczny nie używa aplikacji" />
                                <Switch
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    IsToggled="{Binding InactivityAlertsEnabled}"
                                    VerticalOptions="Center" />
                            </Grid>

                            <Grid
                                ColumnDefinitions="*, Auto"
                                ColumnSpacing="10"
                                IsVisible="{Binding InactivityAlertsEnabled}"
                                RowDefinitions="Auto, Auto">
                                <Label Style="{StaticResource TitleLabelStyle}" Text="Limit braku aktywności" />
                                <Label
                                    Grid.Row="1"
                                    Style="{StaticResource SubtitleLabelStyle}"
                                    Text="Po ilu godzinach chcesz alert?" />

                                <HorizontalStackLayout
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    HorizontalOptions="End"
                                    Spacing="10"
                                    VerticalOptions="Center">
                                    <Stepper
                                        Increment="1"
                                        Maximum="168"
                                        Minimum="1"
                                        Value="{Binding InactivityThresholdHours}" />
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="{Binding InactivityThresholdHours, StringFormat='{0} h'}"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="Uprawnienia systemowe" />
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid
                        ColumnDefinitions="*, Auto"
                        ColumnSpacing="10"
                        RowDefinitions="Auto, Auto">
                        <Label Style="{StaticResource TitleLabelStyle}" Text="Zarządzaj uprawnieniami" />
                        <Label
                            Grid.Row="1"
                            Style="{StaticResource SubtitleLabelStyle}"
                            Text="Otwórz ustawienia systemowe, aby zmienić uprawnienia" />
                        <Button
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            Command="{Binding OpenSystemSettingsCommand}"
                            Text="Otwórz"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="Konto" />
                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10" VerticalOptions="Center">
                        <Button Command="{Binding GoToManageAccountCommand}" Text="Zarządzaj swoim kontem" />
                        <Button
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Text="Wyloguj się" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Button
                Margin="0,10,0,20"
                Command="{Binding SaveSettingsCommand}"
                Text="Zapisz ustawienia" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>