<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="i_am.Pages.Main.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:i_am.ViewModels"
    xmlns:local="clr-namespace:i_am.Resources.Strings"
    Title="{Binding Source={x:Static local:AppStrings.Settings_Title}}"
    x:DataType="vm:SettingsViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_AppearanceAndLanguage}}" />

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_Theme}}" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_ThemeDesc}}" />
                        </VerticalStackLayout>

                        <Picker
                            Grid.Column="1"
                            HorizontalOptions="End"
                            ItemsSource="{Binding ThemeOptions}"
                            SelectedItem="{Binding SelectedTheme}"
                            WidthRequest="150" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_Language}}" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_LanguageDesc}}" />
                        </VerticalStackLayout>

                        <Picker
                            Grid.Column="1"
                            HorizontalOptions="End"
                            ItemsSource="{Binding LanguageOptions}"
                            SelectedItem="{Binding SelectedLanguage}"
                            WidthRequest="150" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsCareTaker}" Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_TimeAndReports}}" />

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_DayStart}}" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_DayStartDesc}}" />
                        </VerticalStackLayout>
                        <Picker
                            Grid.Column="1"
                            ItemsSource="{Binding HoursList}"
                            SelectedItem="{Binding SelectedDayStartHour}"
                            WidthRequest="100" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_RestrictActivityTime}}" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_RestrictActivityTimeDesc}}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding IsActivityTimeRestricted}" />
                    </Grid>
                </Border>

                <Border IsVisible="{Binding IsActivityTimeRestricted}" Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_TimeWindow}}" />
                        <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="10">
                            <Picker
                                Title="{Binding Source={x:Static local:AppStrings.Settings_From}}"
                                Grid.Column="0"
                                ItemsSource="{Binding HoursList}"
                                SelectedItem="{Binding SelectedRestrictionStartHour}" />
                            <Label
                                Grid.Column="1"
                                Text="{Binding Source={x:Static local:AppStrings.Settings_To}}"
                                VerticalOptions="Center" />
                            <Picker
                                Title="{Binding Source={x:Static local:AppStrings.Settings_To}}"
                                Grid.Column="2"
                                ItemsSource="{Binding HoursList}"
                                SelectedItem="{Binding SelectedRestrictionEndHour}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_Notifications}}" />

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_PushNotifications}}" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_PushNotificationsDesc}}" />
                        </VerticalStackLayout>

                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding AreNotificationsEnabled}"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource HeaderLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_SystemPermissions}}" />

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Style="{StaticResource TitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_ManagePermissions}}" />
                            <Label Style="{StaticResource SubtitleLabelStyle}" Text="{Binding Source={x:Static local:AppStrings.Settings_ManagePermissionsDesc}}" />
                        </VerticalStackLayout>

                        <Button
                            Grid.Column="1"
                            Command="{Binding OpenSystemSettingsCommand}"
                            Text="{Binding Source={x:Static local:AppStrings.Settings_Open}}"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Button
                    Margin="0,10,0,20"
                    Command="{Binding SaveSettingsCommand}"
                    Text="{Binding Source={x:Static local:AppStrings.Settings_Save}}" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>