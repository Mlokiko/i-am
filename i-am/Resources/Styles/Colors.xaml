<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#4A90E2</Color>
    <Color x:Key="PrimaryDark">#356AAB</Color>
    <Color x:Key="PrimaryDarkText">#E8EAED</Color>

    <Color x:Key="Secondary">#81C784</Color>
    <Color x:Key="SecondaryDarkText">#5E9CA0</Color>

    <Color x:Key="DangerLight">#E57373</Color>
